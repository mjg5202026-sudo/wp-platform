@fault_bp.route("/analysis/monthly", methods=["GET"])
def analysis_monthly():
    """月报分析 GET /api/faults/analysis/monthly?year=2026&month=6"""
    year = request.args.get("year", type=int)
    month = request.args.get("month", type=int)

    if not year or not month:
        return jsonify({"error": "请指定 year 和 month 参数"}), 400

    try:
        from backend.services.failure_analysis_service import (
            run_monthly_analysis, result_to_dict
        )
        from backend.models import db

        result = run_monthly_analysis(year, month, db_session=db.session)
        data = result_to_dict(result)
        return jsonify({"data": data})
    except Exception as e:
        return jsonify({"error": str(e)}), 500


@fault_bp.route("/analysis/custom", methods=["GET"])
def analysis_custom():
    """自定义分析 GET /api/faults/analysis/custom?start=2026-06-01&end=2026-06-29"""
    start_str = request.args.get("start")
    end_str = request.args.get("end")

    if not start_str or not end_str:
        return jsonify({"error": "请指定 start 和 end 参数 (YYYY-MM-DD)"}), 400

    try:
        from datetime import date
        start = date.fromisoformat(start_str)
        end = date.fromisoformat(end_str)

        from backend.services.failure_analysis_service import (
            run_custom_analysis, result_to_dict
        )
        from backend.models import db

        result = run_custom_analysis(start, end, db_session=db.session)
        data = result_to_dict(result)
        return jsonify({"data": data})
    except ValueError as e:
        return jsonify({"error": f"日期格式错误: {e}"}), 400
    except Exception as e:
        return jsonify({"error": str(e)}), 500


@fault_bp.route("/analysis/quarterly", methods=["GET"])
def analysis_quarterly():
    """季度分析 GET /api/faults/analysis/quarterly?year=2026&quarter=2"""
    year = request.args.get("year", type=int)
    quarter = request.args.get("quarter", type=int)

    if not year or not quarter or quarter not in [1, 2, 3, 4]:
        return jsonify({"error": "请指定 year 和 quarter (1-4)"}), 400

    try:
        q_start = {1: 1, 2: 4, 3: 7, 4: 10}[quarter]
        q_end = {1: 3, 2: 6, 3: 9, 4: 12}[quarter]
        import calendar
        from datetime import date

        start = date(year, q_start, 1)
        last_day = calendar.monthrange(year, q_end)[1]
        end = date(year, q_end, last_day)

        from backend.services.failure_analysis_service import (
            run_custom_analysis, result_to_dict
        )
        from backend.models import db

        result = run_custom_analysis(start, end, db_session=db.session)
        data = result_to_dict(result)
        return jsonify({"data": data})
    except Exception as e:
        return jsonify({"error": str(e)}), 500
