W_NS = 'http://schemas.openxmlformats.org/wordprocessingml/2006/main'
R_NS = 'http://schemas.openxmlformats.org/officeDocument/2006/relationships'

def q(tag):
    return '{' + W_NS + '}' + tag

def make_rpr(font='宋体', sz=21, bold=False, color=None, hint=None):
    rpr = ET.SubElement(ET.Element(q('rPr')), q('rPr'))
    # don't nest - create fresh
    rpr_elem = ET.Element(q('rPr'))
    rFonts = ET.SubElement(rpr_elem, q('rFonts'))
    rFonts.set(q('ascii'), font)
    rFonts.set(q('eastAsia'), font)
    rFonts.set(q('hAnsi'), font)
    rFonts.set(q('cs'), font)
    if hint:
        rFonts.set(q('hint'), hint)
    if bold:
        ET.SubElement(rpr_elem, q('b'))
        ET.SubElement(rpr_elem, q('bCs'))
    sz_elem = ET.SubElement(rpr_elem, q('sz'))
    sz_elem.set(q('val'), str(sz))
    szCs_elem = ET.SubElement(rpr_elem, q('szCs'))
    szCs_elem.set(q('val'), str(sz+3 if sz <= 24 else sz))
    if color:
        c_elem = ET.SubElement(rpr_elem, q('color'))
        c_elem.set(q('val'), color)
    lang = ET.SubElement(rpr_elem, q('lang'))
    lang.set(q('eastAsia'), 'zh-CN')
    return rpr_elem

def make_run(text, font='宋体', sz=21, bold=False, color=None, hint=None):
    r = ET.Element(q('r'))
    rpr = make_rpr(font, sz, bold, color, hint)
    r.append(rpr)
    t = ET.SubElement(r, q('t'))
    t.text = text
    t.set('{http://www.w3.org/XML/1998/namespace}space', 'preserve')
    return r

def make_paragraph(text, font='宋体', sz=21, bold=False, jc=None, first_line_indent=None, spacing_before=None, spacing_after=None, color=None):
    p = ET.Element(q('p'))
    pPr = ET.SubElement(p, q('pPr'))

    if jc:
        jc_elem = ET.SubElement(pPr, q('jc'))
        jc_elem.set(q('val'), jc)

    if first_line_indent:
        ind = ET.SubElement(pPr, q('ind'))
        ind.set(q('firstLine'), str(first_line_indent))

    if spacing_before is not None or spacing_after is not None:
        spacing = ET.SubElement(pPr, q('spacing'))
        if spacing_before is not None:
            spacing.set(q('before'), str(spacing_before))
        if spacing_after is not None:
            spacing.set(q('after'), str(spacing_after))

    if text:
        run = make_run(text, font, sz, bold, color)
        p.append(run)
    return p

def make_section_props():
    """Create section properties with A4 page size."""
    sectPr = ET.Element(q('sectPr'))
    pgSz = ET.SubElement(sectPr, q('pgSz'))
    pgSz.set(q('w'), '11906')  # A4 width
    pgSz.set(q('h'), '16838')  # A4 height
    pgMar = ET.SubElement(sectPr, q('pgMar'))
    pgMar.set(q('top'), '1440')    # 1 inch
    pgMar.set(q('right'), '1440')
    pgMar.set(q('bottom'), '1440')
    pgMar.set(q('left'), '1440')
    pgMar.set(q('header'), '720')
    pgMar.set(q('footer'), '720')
    return sectPr


