import os
from flask import Flask
from flask_cors import CORS
from flask_sqlalchemy import SQLAlchemy

db = None


def create_app(config_name=None):
    """Flask应用工厂"""
    app = Flask(__name__,
                static_folder=None,
                template_folder=None)

    app.config.from_object("backend.config")
    app.config["SQLALCHEMY_TRACK_MODIFICATIONS"] = False

    from backend.models import db as _db
    global db
    db = _db
    db.init_app(app)
    CORS(app)

    from backend.routes.data_routes import data_bp
    from backend.routes.fault_routes import fault_bp
    from backend.routes.inspection_routes import inspection_bp
    from backend.routes.project_routes import project_bp
    from backend.routes.assessment_routes import assessment_bp
    from backend.routes.report_routes import report_bp
    from backend.routes.energy_routes import energy_bp

    app.register_blueprint(data_bp, url_prefix="/api/data")
    app.register_blueprint(fault_bp, url_prefix="/api/faults")
    app.register_blueprint(inspection_bp, url_prefix="/api/inspections")
    app.register_blueprint(project_bp, url_prefix="/api/projects")
    app.register_blueprint(assessment_bp, url_prefix="/api/assessments")
    app.register_blueprint(report_bp, url_prefix="/api/reports")
    app.register_blueprint(energy_bp, url_prefix="/api/energy")

    @app.route("/api/health")
    def health_check():
        return {"status": "ok", "message": "WP平台运行中"}

    with app.app_context():
        from backend.models import (
            OperationImpactFactor, FaultStatistic,
            MaterialConsumption, EnergyConsumption,
            InventoryTarget, InspectionIssue, Project,
            PerformanceAssessment, AiReviewRecord
        )
        from backend.models_kpi import AssessmentKpiResult
        db.create_all()

    return app
