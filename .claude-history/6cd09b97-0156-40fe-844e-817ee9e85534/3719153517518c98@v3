@fault_bp.route("/daily-trend", methods=["GET"])
def get_daily_trend():
    """??????"""
    days = request.args.get("days", 30, type=int)
    start = datetime.now().date() - timedelta(days=days)

    records = db.session.query(
        OperationImpactFactor.date,
        func.count(OperationImpactFactor.id).label("count"),
        func.sum(OperationImpactFactor.impact_minutes).label("total_minutes"),
    ).filter(OperationImpactFactor.date >= start)\
     .group_by(OperationImpactFactor.date)\
     .order_by(OperationImpactFactor.date).all()

    return jsonify({
        "data": [{
            "date": str(r.date) if r.date else None,
            "count": r.count,
            "total_minutes": r.total_minutes or 0,
            "total_hours": round((r.total_minutes or 0) / 60, 2),
        } for r in records]
    })


@fault_bp.route("/summary", methods=["GET"])
def get_summary():
    """??????"""
    total = OperationImpactFactor.query.count()
    total_minutes = db.session.query(func.sum(OperationImpactFactor.impact_minutes)).scalar() or 0
    avg_minutes = total_minutes / total if total > 0 else 0
    impact_types = db.session.query(
        OperationImpactFactor.impact_type,
        func.count(OperationImpactFactor.id).label("count")
    ).group_by(OperationImpactFactor.impact_type).all()

    return jsonify({
        "data": {
            "total_records": total,
            "total_minutes": total_minutes,
            "total_hours": round(total_minutes / 60, 2),
            "avg_minutes_per_record": round(avg_minutes, 1),
            "by_type": {r.impact_type or "??": r.count for r in impact_types},
        }
    })


