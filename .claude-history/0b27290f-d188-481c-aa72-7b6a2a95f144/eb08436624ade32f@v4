}

def read_quota_data(excel_path, year, month):
    """从年度考核Excel读取定额材料5月数据"""
    import openpyxl
    wb = openpyxl.load_workbook(excel_path, data_only=True)
    ws = wb['26年单耗计算表 (1-5月) (剔除)']

    # 找到对应月份的数据列
    # 表头R4: 序号 | 指标 | ... | 业绩目标 | 1月目标|1月实际|单耗|超幅|...|5月目标|5月实际|单耗|超幅|...
    header = []
    for c in range(1, ws.max_column + 1):
        v = ws.cell(4, c).value
        header.append(str(v) if v else "")

    # 定位5月数据的列: 每个月占5列 (目标,实际,单耗,超幅,考核)
    # 但Q1合计(5列)插在3月和4月之间，所以4月/5月偏移+5
    if month <= 3:
        month_target_col = 8 + (month - 1) * 5
    else:
        month_target_col = 8 + (month - 1) * 5 + 5
    # 目标, 实际, 单耗, 超幅, 考核
    month_actual_col = month_target_col + 1
    month_unit_col = month_target_col + 2
    month_rate_col = month_target_col + 3

    # 读取定额材料数据
    quota_rows = {
        "电极糊": 5,
        "镁质炮泥": 6,
        "无水炮泥": 7,
        "绿泥": 8,
        "脱模剂": 10,
    }

    results = []
    for name, row_idx in quota_rows.items():
        target_val = ws.cell(row_idx, month_target_col).value
        actual_val = ws.cell(row_idx, month_actual_col).value
        unit_val = ws.cell(row_idx, month_unit_col).value  # 实际单耗
        rate_val = ws.cell(row_idx, month_rate_col).value
        target_unit_val = ws.cell(row_idx, 7).value  # 业绩目标单耗（固定列）

        target = float(target_val) if target_val else 0
        actual = float(actual_val) if actual_val else 0
        actual_unit = float(unit_val) if unit_val else 0
        target_unit_budget = float(target_unit_val) if target_unit_val else 0
        rate = float(rate_val) if rate_val else 0

        # 影响数量 = 实际 - 目标 (超预算数量)
        impact_qty = round(actual - target, 2)

        # 影响金额 = 超预算数量 * 预算单价
        unit_price = QUOTA_PRICES.get(name, 0)
        impact_amount = round(impact_qty * unit_price, 2)

        # 考核金额 = 超幅 * 影响金额 (月评季考)
        penalty = round(rate * impact_amount, 2)

        # 超幅显示
        rate_display = f"{rate*100:.2f}%" if rate > 0 else "/"

        results.append({
            "name": name,
            "target_unit": target_unit_budget,  # 业绩目标单耗（如0.07063）
            "actual_unit": round(actual_unit, 4),  # 实际单耗
            "target_qty": target,
            "actual_qty": actual,
            "rate_display": rate_display,
            "rate": rate,
            "impact_qty": impact_qty,
            "impact_amount": impact_amount,
            "penalty": penalty,
        })

    wb.close()
    return results


