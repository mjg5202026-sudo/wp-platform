class ExcelImportResult:
    """导入结果"""
    def __init__(self):
        self.success = 0
        self.errors = []
        self.table_name = ""

    def add_success(self, count: int = 1):
        self.success += count

    def add_error(self, row: int, msg: str):
        self.errors.append({"row": row, "message": str(msg)})

    def to_dict(self):
        return {
            "table": self.table_name,
            "success": self.success,
            "errors": self.errors[:20],
            "status": "ok" if not self.errors else "partial_error"
        }


