        elif "能源" in fname or "能耗" in fname or "电" in fname or "柴油" in fname:
            return import_energy(file_path)
        else:
            result.add_error(0, f"无法识别文件类型: {fname}")
            return result

    # 按指定表名导入
    importers = {
        "impact_factors": import_impact_factors,
        "materials": import_materials,
        "energy": import_energy,
    }
    importer = importers.get(table_name)
    if importer:
        return importer(file_path)
    else:
        result.add_error(0, f"不支持的表名: {table_name}")
        return result
