                    db.session.add(record)
                    result.add_success()
                except Exception as e:
                    result.add_error(r + 1, str(e))
        else:
            # openpyxl .xlsx 文件处理
            header_row = detect_header_row(ws)
            if not header_row:
                result.add_error(0, "未检测到表头行")
                return result
            headers = parse_header_row(ws, header_row)
            for r in range(header_row + 1, ws.max_row + 1):
                try:
                    row_data = {}
                    is_empty = True
                    for c, h in enumerate(headers):
                        if c >= len(headers):
