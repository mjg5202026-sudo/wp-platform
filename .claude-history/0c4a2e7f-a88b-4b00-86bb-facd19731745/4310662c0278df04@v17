def sf(run, fn='宋体', ea='宋体', sz=16, b=False):
    run.font.size = Pt(sz); run.bold = b
    rPr = run._element.find(qn('w:rPr'))
    if rPr is None: rPr = OxmlElement('w:rPr'); run._element.insert(0, rPr)
    rF = rPr.find(qn('w:rFonts'))
    if rF is None: rF = OxmlElement('w:rFonts'); rPr.insert(0, rF)
    rF.set(qn('w:ascii'), fn); rF.set(qn('w:hAnsi'), fn); rF.set(qn('w:eastAsia'), ea)

def T(doc, text):
    p = doc.add_paragraph(); p.alignment = WD_ALIGN_PARAGRAPH.CENTER; run = p.add_run(text); sf(run, '方正小标宋简体', '方正小标宋简体', 24)
def ST(doc, text):
    p = doc.add_paragraph(); p.alignment = WD_ALIGN_PARAGRAPH.CENTER; run = p.add_run(text); sf(run, sz=16)
def H1(doc, text):
    p = doc.add_paragraph(); p.alignment = WD_ALIGN_PARAGRAPH.JUSTIFY; run = p.add_run(text); sf(run, sz=16); p.paragraph_format.space_before = Pt(12)
