// Helper functions
function tr(text, opts = {}) {
  return new TextRun({ text, font: opts.font || FONT, size: opts.size || 21, bold: opts.bold || false });
}

function p(children, opts = {}) {
  const arr = Array.isArray(children) ? children : [tr(children)];
  return new Paragraph({
    children: arr,
    alignment: opts.alignment,
    spacing: opts.spacing || { after: 40 },
    indent: opts.indent,
  });
}

function empty() {
  return new Paragraph({ children: [tr("")], spacing: { after: 40 } });
}

function bodyLine(text, indent = true) {
  return new Paragraph({
    children: [tr(text)],
    indent: indent ? { firstLine: 420 } : undefined,
    spacing: { after: 40 },
  });
}

function heading(text) {
  return new Paragraph({
    children: [tr(text, { bold: true, size: 24 })],
    spacing: { before: 200, after: 100 },
    keepNext: true,
  });
}

function biLine(zh, id) {
  return new Paragraph({
    children: [
      tr(zh),
      tr("  /  ", { font: TITLE_FONT, size: 18 }),
      tr(id, { font: TITLE_FONT, size: 18 }),
    ],
    indent: { firstLine: 420 },
    spacing: { after: 60 },
  });
}

function biHeading(zh, id) {
  return new Paragraph({
    children: [
      tr(zh, { bold: true, size: 24 }),
      tr("  /  ", { font: TITLE_FONT, size: 24 }),
      tr(id, { font: TITLE_FONT, bold: true, size: 24 }),
    ],
    spacing: { before: 200, after: 100 },
    keepNext: true,
  });
}

