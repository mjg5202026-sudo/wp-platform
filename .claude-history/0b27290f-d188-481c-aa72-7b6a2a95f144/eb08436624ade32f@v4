            if i + 1 < len(table.rows):
                row = table.rows[i + 1]
                cells = row.cells
                if len(cells) >= 8:
                    # 序号 - 已在模板中
                    # 指标 - 已在模板中
                    # 被考核单位 - 冶炼部
                    cells[2].text = "冶炼部"
                    # 单位
                    cells[3].text = "吨/吨镍铁"
                    # 业绩目标
                    cells[4].text = str(data.get("target_unit", ""))
                    # 5月实际业绩 (单耗)
                    cells[5].text = str(data.get("actual_unit", ""))
                    # 超幅
                    cells[6].text = data["rate_display"]
                    # 奖罚金额
                    cells[7].text = "/"  # 月评季考
                    # 考核频次 - 已在模板中

    # ============================================================
