def import_energy(file_path: str) -> ExcelImportResult:
    """导入能源消耗数据"""
    result = ExcelImportResult()
    result.table_name = "energy_consumptions"

    try:
        wb = load_workbook(file_path)
        ws = wb.active if hasattr(wb, "active") else wb.sheet_by_index(0)

        if hasattr(ws, "nrows"):
            # xlrd .xls 文件处理
            rows_total = ws.nrows
            for r in range(1, rows_total):
                try:
                    vals = [ws.cell_value(r, c) if c < ws.ncols else "" for c in range(9)]
                    if not vals[0] or str(vals[0]).strip() == "":
                        continue
                    raw_date = parse_date_value(vals[0])
                    if isinstance(raw_date, str):
                        try:
                            date_obj = datetime.strptime(raw_date[:10], "%Y-%m-%d").date()
                        except:
                            date_obj = date.today()
                    else:
                        date_obj = raw_date or date.today()

                    record = EnergyConsumption(
                        date=date_obj,
                        energy_type=str(vals[1]).strip() if vals[1] else "",
                        consumption=float(vals[2]) if vals[2] else 0,
                        unit=str(vals[3]).strip() if vals[3] else "",
                        unit_price=float(vals[4]) if vals[4] else 0,
                        total_cost=float(vals[5]) if vals[5] else 0,
                        generation_amount=float(vals[6]) if vals[6] else 0,
                        consumption_per_unit=float(vals[7]) if vals[7] else None,
                        remark=str(vals[8]).strip() if vals[8] else "",
                        created_at=datetime.now(),
                    )
                    db.session.add(record)
                    result.add_success()
                except Exception as e:
                    result.add_error(r + 1, str(e))
        else:
            # openpyxl .xlsx 文件处理
            header_row = detect_header_row(ws)
            if not header_row:
                result.add_error(0, "未检测到表头行")
                return result
            headers = parse_header_row(ws, header_row)
            for r in range(header_row + 1, ws.max_row + 1):
                try:
                    row_data = {}
                    is_empty = True
                    for c, h in enumerate(headers):
                        if c >= len(headers):
                            break
                        v = ws.cell(r, c + 1).value
                        if v is not None:
                            is_empty = False
                        row_data[h] = v
                    if is_empty:
                        continue
                    record = _build_energy_from_headers(row_data)
                    if record:
                        db.session.add(record)
                        result.add_success()
                except Exception as e:
                    result.add_error(r + 1, str(e))

        db.session.commit()
    except Exception as e:
        db.session.rollback()
        result.add_error(0, f"导入失败: {str(e)}")

    return result


def _build_energy_from_headers(row_data: dict):
    """从表头映射构建能源消耗记录"""
    raw_date = row_data.get("date") or row_data.get("日期")
    if not raw_date:
        return None
    if isinstance(raw_date, str):
        try:
            date_obj = datetime.strptime(raw_date[:10], "%Y-%m-%d").date()
        except:
            date_obj = date.today()
    else:
        date_obj = raw_date

    return EnergyConsumption(
        date=date_obj,
        energy_type=str(row_data.get("energy_type", "")),
        consumption=float(row_data.get("consumption", 0) or 0),
        unit=str(row_data.get("unit", "")),
        unit_price=float(row_data.get("unit_price", 0) or 0),
        total_cost=float(row_data.get("total_cost", 0) or 0),
        generation_amount=float(row_data.get("generation_amount", 0) or 0),
        consumption_per_unit=float(row_data.get("consumption_per_unit", 0)) if row_data.get("consumption_per_unit") else None,
        remark=str(row_data.get("remark", "")),
        created_at=datetime.now(),
    )


# ============================================================
# 自动导入入口（按表名或文件名自动识别）
# ============================================================
def auto_import(file_path: str, table_name: str = None) -> ExcelImportResult:
    """自动导入入口"""
    result = ExcelImportResult()

    # 未指定表名时按文件名自动识别
    if not table_name:
        fname = os.path.basename(file_path)
        if "作业率" in fname:
            return import_impact_factors(file_path)
        elif "物资" in fname or "材料" in fname or "消耗" in fname:
            return import_materials(file_path)
        elif "能源" in fname or "能耗" in fname or "电" in fname or "柴油" in fname:
            return import_energy(file_path)
        else:
            result.add_error(0, f"无法识别文件类型: {fname}")
            return result

    # 按指定表名导入
    importers = {
        "impact_factors": import_impact_factors,
        "materials": import_materials,
        "energy": import_energy,
    }
    importer = importers.get(table_name)
    if importer:
        return importer(file_path)
    else:
        result.add_error(0, f"不支持的表名: {table_name}")
        return result
