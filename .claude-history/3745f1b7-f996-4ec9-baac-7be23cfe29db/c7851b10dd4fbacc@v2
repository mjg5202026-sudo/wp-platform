def create_docx():
    # Create output directory
    if os.path.exists(OUT_DIR):
        shutil.rmtree(OUT_DIR)

    # Copy template files (styles, settings, relationships, etc.)
    shutil.copytree(TEMPLATE_DIR, OUT_DIR)

    # Remove old document.xml
    doc_xml_path = os.path.join(OUT_DIR, 'word', 'document.xml')
    if os.path.exists(doc_xml_path):
        os.remove(doc_xml_path)

    # Register namespaces
    ET.register_namespace('w', W_NS)
    ET.register_namespace('r', R_NS)
    ET.register_namespace('mc', 'http://schemas.openxmlformats.org/markup-compatibility/2006')
    ET.register_namespace('w14', 'http://schemas.microsoft.com/office/word/2010/wordml')
    ET.register_namespace('w15', 'http://schemas.microsoft.com/office/word/2012/wordml')
    ET.register_namespace('w16cex', 'http://schemas.microsoft.com/office/word/2018/wordml/cex')
    ET.register_namespace('w16cid', 'http://schemas.microsoft.com/office/word/2016/wordml/cid')
    ET.register_namespace('w16', 'http://schemas.microsoft.com/office/word/2018/wordml')
    ET.register_namespace('w16sdtdh', 'http://schemas.microsoft.com/office/word/2020/wordml/sdtdatahash')
    ET.register_namespace('w16se', 'http://schemas.microsoft.com/office/word/2015/wordml/symex')

    # Build document
    document = ET.Element('{http://schemas.openxmlformats.org/wordprocessingml/2006/main}document')
    document.set('{http://schemas.openxmlformats.org/officeDocument/2006/relationships}mc:Ignorable', 'w14 w15 w16se w16cid w16 w16cex w16sdtdh')

    body = build_document()
    document.append(body)

    # Write XML
    tree = ET.ElementTree(document)
    tree.write(doc_xml_path, xml_declaration=True, encoding='UTF-8')

    # Create the docx file (zip)
    docx_dir = os.path.dirname(OUTPUT_FILE)
    if not os.path.exists(docx_dir):
        os.makedirs(docx_dir)

    if os.path.exists(OUTPUT_FILE):
        os.remove(OUTPUT_FILE)

    with zipfile.ZipFile(OUTPUT_FILE, 'w', zipfile.ZIP_DEFLATED) as zf:
        for root, dirs, files in os.walk(OUT_DIR):
            for file in files:
                file_path = os.path.join(root, file)
                arcname = os.path.relpath(file_path, OUT_DIR)
                zf.write(file_path, arcname)

    print('SUCCESS: Created ' + OUTPUT_FILE)
    print('File size: %d bytes' % os.path.getsize(OUTPUT_FILE))

if __name__ == '__main__':
    create_docx()
