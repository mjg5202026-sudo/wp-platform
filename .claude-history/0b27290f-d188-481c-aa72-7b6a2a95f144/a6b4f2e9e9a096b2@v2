        # 4. ??????
        diesel_score = calculate_score(abs(diesel_completion))
        water_score = calculate_score(abs(water_completion))
        lubricant_score = calculate_score(abs(lubricant_completion))
        parts_score = calculate_score(abs(parts_completion))
        material_score = calculate_score(abs(material_completion))

        # 5. ????????? (??????????????)
        outsourcing_count = 0
        outsourcing_amount = 0.0
        outsourcing_saved = 0.0
        outsourcing_score = 100.0

        equipment_score = 100.0

        # 6. ???? (??)
        details = {
            "diesel_score": diesel_score, "fresh_water_score": water_score,
            "lubricant_score": lubricant_score, "spare_parts_score": parts_score,
            "material_score": material_score, "outsourcing_score": outsourcing_score,
            "equipment_score": equipment_score,
            "diesel_rate": diesel_rate, "water_rate": water_rate,
            "lubricant_rate": lubricant_rate, "parts_rate": parts_rate,
            "material_rate": material_rate,
            "outsourcing_count": outsourcing_count,
        }

        total_score = round(
            diesel_score * WEIGHTS["diesel"]
            + water_score * WEIGHTS["fresh_water"]
            + lubricant_score * WEIGHTS["lubricant"]
            + parts_score * WEIGHTS["spare_parts"]
            + material_score * WEIGHTS["material"]
            + outsourcing_score * WEIGHTS["outsourcing"]
            + equipment_score * WEIGHTS["equipment"],
            1
        )

        # 7. ??????
        opinion = generate_opinion(total_score, details)

        # 8. ??????
        assessment = PerformanceAssessment(
            assessment_year=year,
            assessment_month=month,
            diesel_reduction_rate=diesel_rate,
            diesel_score=diesel_score,
            fresh_water_reduction_rate=water_rate,
            fresh_water_score=water_score,
            lubricant_reduction_rate=lubricant_rate,
            lubricant_score=lubricant_score,
            spare_parts_reduction_rate=parts_rate,
            spare_parts_score=parts_score,
            material_reduction_rate=material_rate,
            material_score=material_score,
            outsourcing_count=outsourcing_count,
            outsourcing_amount=outsourcing_amount,
            outsourcing_saved=outsourcing_saved,
            outsourcing_score=outsourcing_score,
            equipment_special_score=equipment_score,
            total_score=total_score,
            evaluation_opinion=opinion,
