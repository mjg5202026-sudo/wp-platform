from datetime import datetime, timedelta
from flask import Blueprint, request, jsonify
from sqlalchemy import func, extract

from backend.models import db, OperationImpactFactor, FaultStatistic

fault_bp = Blueprint("faults", __name__)


@fault_bp.route("/list", methods=["GET"])
def get_faults():
    """??????"""
    page = request.args.get("page", 1, type=int)
    per_page = request.args.get("per_page", 50, type=int)
    query = FaultStatistic.query.order_by(FaultStatistic.id.desc())

    total = query.count()
    records = query.offset((page - 1) * per_page).limit(per_page).all()
    return jsonify({
        "data": [r.to_dict() for r in records],
        "total": total,
        "page": page,
        "per_page": per_page,
    })


@fault_bp.route("/impact-list", methods=["GET"])
def get_impact_list():
    """??????????? (???)"""
    page = request.args.get("page", 1, type=int)
    per_page = request.args.get("per_page", 50, type=int)
    query = OperationImpactFactor.query

    # ??
    date_from = request.args.get("date_from")
    date_to = request.args.get("date_to")
    team = request.args.get("team")
    system = request.args.get("system")
    impact_type = request.args.get("impact_type")

    if date_from:
        query = query.filter(OperationImpactFactor.date >= date_from)
    if date_to:
        query = query.filter(OperationImpactFactor.date <= date_to)
    if team:
        query = query.filter(OperationImpactFactor.team == team)
    if system:
        query = query.filter(OperationImpactFactor.system.like(f"%{system}%"))
    if impact_type:
        query = query.filter(OperationImpactFactor.impact_type == impact_type)

    query = query.order_by(OperationImpactFactor.date.desc())
    total = query.count()
    records = query.offset((page - 1) * per_page).limit(per_page).all()

    return jsonify({
        "data": [r.to_dict() for r in records],
        "total": total,
        "page": page,
        "per_page": per_page,
    })


@fault_bp.route("/top10", methods=["GET"])
def get_top10():
    """TOP10 ??????"""
    start_date = request.args.get("date_from")
    end_date = request.args.get("date_to")

    query = db.session.query(
        OperationImpactFactor.impact_factor,
        func.count(OperationImpactFactor.id).label("count"),
        func.sum(OperationImpactFactor.impact_minutes).label("total_minutes"),
    )

    if start_date:
        query = query.filter(OperationImpactFactor.date >= start_date)
    if end_date:
        query = query.filter(OperationImpactFactor.date <= end_date)

    records = query.group_by(OperationImpactFactor.impact_factor)\
        .order_by(func.sum(OperationImpactFactor.impact_minutes).desc())\
        .limit(10).all()

    data = [{
        "factor": r.impact_factor,
        "count": r.count,
        "total_minutes": r.total_minutes or 0,
        "total_hours": round((r.total_minutes or 0) / 60, 2),
    } for r in records]

    return jsonify({"data": data})


