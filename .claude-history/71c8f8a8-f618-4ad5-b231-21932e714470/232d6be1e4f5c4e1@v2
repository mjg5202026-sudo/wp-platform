# -*- coding: utf-8 -*-
"""
故障率分析服务层

包装 analysis 包，供 Flask 路由调用。
支持 Excel 和 DB 两种数据源。
"""
import os
from datetime import date
from typing import Optional


def get_default_excel_path() -> str:
    """获取默认Excel文件路径（从backend目录向上查找）"""
    base = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    data_dir = os.path.join(base, "..", "data", "templates")
    data_dir = os.path.abspath(data_dir)

    if not os.path.isdir(data_dir):
        return ""

    for f in sorted(os.listdir(data_dir)):
        if "影响作业率" in f and (f.endswith('.xls') or f.endswith('.xlsx')):
            return os.path.join(data_dir, f)
    return ""


def run_analysis(start_date: date, end_date: date,
                 excel_path: Optional[str] = None,
                 db_session=None,
                 running_lines=None,
                 top_n: int = 10):
    """
    运行故障率分析

    参数:
        start_date: 开始日期
        end_date: 结束日期
        excel_path: Excel文件路径（优先用于加载数据）
        db_session: SQLAlchemy会话（Excel不可用时fallback）
        running_lines: 运行产线列表，默认 [1,2,3]
        top_n: 返回Top N因素

    返回:
        AnalysisResult 对象
    """
    from backend.analysis.classifier import Classifier
    from backend.analysis.engine import calculate

    cls = Classifier()
    records = []

    # 优先从Excel加载
    if excel_path and os.path.exists(excel_path):
        from backend.analysis.loader import ExcelLoader
        loader = ExcelLoader(excel_path, classifier=cls)
        records = loader.load_by_date_range(start_date, end_date)
    elif db_session:
        from backend.analysis.loader import DBLoader
        loader = DBLoader(session=db_session, classifier=cls)
        records = loader.load_by_date_range(start_date, end_date)
    else:
        # 自动查找
        path = get_default_excel_path()
        if path:
            from backend.analysis.loader import ExcelLoader
            loader = ExcelLoader(path, classifier=cls)
            records = loader.load_by_date_range(start_date, end_date)

    if not records:
        from backend.analysis.engine import AnalysisResult
        return AnalysisResult(
            period_label="无数据",
            start_date=start_date,
            end_date=end_date,
            days=(end_date - start_date).days + 1,
            running_line_count=len(running_lines or [1, 2, 3]),
            total_line_hours=0,
        )

    # 使用实际数据中的最大日期调整计算天数
    actual_end = max(r.date for r in records)
    actual_start = min(r.date for r in records)
    days = (actual_end - actual_start).days + 1

    result = calculate(records, days=days,
                       running_lines=running_lines,
                       top_n=top_n, classifier=cls)
    return result


def run_monthly_analysis(year: int, month: int, **kwargs):
    """月度故障率分析"""
    import calendar
    from datetime import date
    start = date(year, month, 1)
    last_day = calendar.monthrange(year, month)[1]
    end = date(year, month, last_day)
    # 如果是当前月份，限制到今天
    today = date.today()
    if year == today.year and month == today.month:
        end = today
    return run_analysis(start, end, **kwargs)


def run_custom_analysis(start_date: date, end_date: date, **kwargs):
    """自定义时间范围故障率分析"""
    return run_analysis(start_date, end_date, **kwargs)


def result_to_dict(result):
    """将 AnalysisResult 转为 JSON 可序列化字典"""
    from backend.analysis.formatter import format_json
    return format_json(result)
