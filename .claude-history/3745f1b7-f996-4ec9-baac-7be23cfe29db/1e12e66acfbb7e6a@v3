def alignment_str(align):
    """Convert alignment enum to string."""
    mapping = {
        None: "None (inherited)",
        WD_ALIGN_PARAGRAPH.LEFT: "LEFT",
        WD_ALIGN_PARAGRAPH.CENTER: "CENTER",
        WD_ALIGN_PARAGRAPH.RIGHT: "RIGHT",
        WD_ALIGN_PARAGRAPH.JUSTIFY: "JUSTIFY",
    }
    return mapping.get(align, str(align))

def emu_to_cm(emu):
    """Convert EMU to cm."""
    if emu is None:
        return None
    return round(emu / 360000, 2)

def twip_to_cm(twip):
    """Convert twips (dxa) to cm. 1 twip = 1/1440 inch."""
    if twip is None:
        return None
    return round(twip / 1440 * 2.54, 2)

def twip_to_pt(twip):
    """Convert twips to points. 1 pt = 20 twips."""
    if twip is None:
        return None
    return round(twip / 20, 1)

def emu_to_pt(emu):
    """Convert EMU to pt."""
    if emu is None:
        return None
    return round(emu / 12700, 1)

def pt_or_none(val):
    """Return value in pt or None (val is in EMU, convert to pt)."""
    if val is None:
        return None
    return round(val / 12700, 1)

def bool_or_none(val):
    if val is None:
        return "None"
    return str(val)

def get_font_info(run):
    """Extract detailed font info from a run."""
    font = run.font
    info = {}
    info['text'] = run.text

    # Font name
    info['font_name'] = font.name
    # East Asian font name
    rPr = run._element.find(qn('w:rPr'))
    if rPr is not None:
        rFonts = rPr.find(qn('w:rFonts'))
        if rFonts is not None:
            info['font_name_ascii'] = rFonts.get(qn('w:ascii'))
            info['font_name_hansi'] = rFonts.get(qn('w:hAnsi'))
            info['font_name_eastAsia'] = rFonts.get(qn('w:eastAsia'))

    # Font size
    info['font_size'] = pt_or_none(font.size) if font.size else None
    # Bold
    info['bold'] = bool_or_none(font.bold)
    # Italic
    info['italic'] = bool_or_none(font.italic)
    # Underline
    info['underline'] = bool_or_none(font.underline)
    # Color
    if font.color and font.color.rgb:
        info['color'] = str(font.color.rgb)
    else:
        info['color'] = None
    # Strike
    info['strike'] = bool_or_none(font.strike)
    # Superscript/subscript
    info['superscript'] = bool_or_none(font.superscript)
    info['subscript'] = bool_or_none(font.subscript)

    return info


def get_paragraph_info(para):
    """Extract detailed paragraph info."""
    info = {}
    info['text'] = para.text
    info['style'] = para.style.name if para.style else "None"
    info['alignment'] = alignment_str(para.alignment)

    fmt = para.paragraph_format
    info['first_line_indent'] = emu_to_cm(fmt.first_line_indent)
    info['left_indent'] = emu_to_cm(fmt.left_indent)
    info['right_indent'] = emu_to_cm(fmt.right_indent)
    info['space_before'] = pt_or_none(fmt.space_before)
    info['space_after'] = pt_or_none(fmt.space_after)

    # Line spacing
    line_spacing = fmt.line_spacing
    if line_spacing is not None:
        info['line_spacing'] = round(line_spacing, 2)
    else:
        info['line_spacing'] = None
    info['line_spacing_rule'] = str(fmt.line_spacing_rule) if fmt.line_spacing_rule else None

    # Keep with next / page break before
    info['keep_with_next'] = fmt.keep_with_next
    info['page_break_before'] = fmt.page_break_before
    info['widow_control'] = fmt.widow_control

    # Outline level (for headings that aren't using heading styles)
    pPr = para._element.find(qn('w:pPr'))
    if pPr is not None:
        outlineLvl = pPr.find(qn('w:outlineLvl'))
        if outlineLvl is not None:
            info['outline_level'] = outlineLvl.get(qn('w:val'))

    # Paragraph borders
    pBdr = pPr.find(qn('w:pBdr')) if pPr is not None else None
    if pBdr is not None:
        info['borders'] = {}
        for side in ['top', 'bottom', 'left', 'right', 'between']:
            side_el = pBdr.find(qn(f'w:{side}'))
            if side_el is not None:
                info['borders'][side] = {
                    'val': side_el.get(qn('w:val')),
                    'sz': side_el.get(qn('w:sz')),
                    'color': side_el.get(qn('w:color')),
                    'space': side_el.get(qn('w:space')),
                }

    # Shading
    shd = pPr.find(qn('w:shd')) if pPr is not None else None
    if shd is not None:
        info['shading'] = {
            'val': shd.get(qn('w:val')),
            'color': shd.get(qn('w:color')),
            'fill': shd.get(qn('w:fill')),
        }

    # Numbering
    numPr = pPr.find(qn('w:numPr')) if pPr is not None else None
    if numPr is not None:
        numId = numPr.find(qn('w:numId'))
        ilvl = numPr.find(qn('w:ilvl'))
        info['numbering'] = {
            'numId': numId.get(qn('w:val')) if numId is not None else None,
            'ilvl': ilvl.get(qn('w:val')) if ilvl is not None else None,
        }

    # Runs
    info['runs'] = []
    for run in para.runs:
        info['runs'].append(get_font_info(run))

    # Hyperlinks in paragraph
    info['hyperlinks'] = []
    for hyperlink in para._element.findall('.//' + qn('w:hyperlink')):
        link_info = {}
        link_info['rId'] = hyperlink.get(qn('r:id'))
        # Get display text
        texts = [t.text for t in hyperlink.findall('.//' + qn('w:t'))]
        link_info['text'] = ''.join(texts)
        info['hyperlinks'].append(link_info)

    # Page breaks
    if pPr is not None:
        pb = pPr.find(qn('w:pageBreakBefore'))
        info['xml_page_break_before'] = pb is not None
        # Check for lastRenderedPageBreak in runs
        info['has_page_break_in_run'] = False
        for run in para.runs:
            br_elements = run._element.findall('.//' + qn('w:br'))
            for br in br_elements:
                if br.get(qn('w:type')) == 'page':
                    info['has_page_break_in_run'] = True
                    break

    return info


def get_cell_info(cell):
    """Extract detailed cell info."""
    info = {}
    info['text'] = cell.text

    # Cell shading
    tc = cell._tc
    tcPr = tc.find(qn('w:tcPr'))
    if tcPr is not None:
        shd = tcPr.find(qn('w:shd'))
        if shd is not None:
            info['shading'] = {
                'val': shd.get(qn('w:val')),
                'color': shd.get(qn('w:color')),
                'fill': shd.get(qn('w:fill')),
            }

        # Cell width
        tcW = tcPr.find(qn('w:tcW'))
        if tcW is not None:
            w_type = tcW.get(qn('w:type'))
            w_val = tcW.get(qn('w:w'))
            info['width'] = {'type': w_type, 'value': w_val,
                'cm': twip_to_cm(int(w_val)) if w_type == 'dxa' and w_val and w_val.isdigit()
                      else emu_to_cm(int(w_val)) if w_val and w_val.isdigit() else None}

        # Vertical alignment
        vAlign = tcPr.find(qn('w:vAlign'))
        if vAlign is not None:
            info['vAlign'] = vAlign.get(qn('w:val'))

        # Cell margins
        tcMar = tcPr.find(qn('w:tcMar'))
        if tcMar is not None:
            info['cell_margins'] = {}
            for side in ['top', 'bottom', 'left', 'right']:
                side_el = tcMar.find(qn(f'w:{side}'))
                if side_el is not None:
                    w_val = side_el.get(qn('w:w'))
                    info['cell_margins'][side] = twip_to_pt(int(w_val)) if w_val and w_val.isdigit() else None

        # Grid span
        gridSpan = tcPr.find(qn('w:gridSpan'))
        if gridSpan is not None:
            info['gridSpan'] = gridSpan.get(qn('w:val'))

        # Vertical merge
        vMerge = tcPr.find(qn('w:vMerge'))
        if vMerge is not None:
            info['vMerge'] = vMerge.get(qn('w:val'))  # 'continue' or 'restart'

        # Text direction
        textDir = tcPr.find(qn('w:textDirection'))
        if textDir is not None:
            info['textDirection'] = textDir.get(qn('w:val'))

    # Paragraphs within cell
    info['paragraphs'] = []
    for para in cell.paragraphs:
        info['paragraphs'].append(get_paragraph_info(para))

    return info


def get_table_info(table, idx):
    """Extract detailed table info."""
    info = {}
    info['table_index'] = idx

    # Table dimensions
    info['rows'] = len(table.rows)
    info['columns'] = len(table.columns)

    # Table alignment
    tbl = table._tbl
    tblPr = tbl.find(qn('w:tblPr'))
    if tblPr is not None:
        tblW = tblPr.find(qn('w:tblW'))
        if tblW is not None:
            w_val = tblW.get(qn('w:w'))
            w_type = tblW.get(qn('w:type'))
            info['width'] = {
                'type': w_type,
                'value': w_val,
                'cm': twip_to_cm(int(w_val)) if w_type == 'dxa' and w_val and w_val.isdigit()
                      else emu_to_cm(int(w_val)) if w_val and w_val.isdigit() else None
            }

        # Table alignment
        jc = tblPr.find(qn('w:jc'))
        if jc is not None:
            info['alignment'] = jc.get(qn('w:val'))

        # Table indentation
        tblInd = tblPr.find(qn('w:tblInd'))
        if tblInd is not None:
            info['indent'] = {
                'w': tblInd.get(qn('w:w')),
                'type': tblInd.get(qn('w:type')),
            }

        # Table borders
        tblBorders = tblPr.find(qn('w:tblBorders'))
        if tblBorders is not None:
            info['borders'] = {}
            for side in ['top', 'bottom', 'left', 'right', 'insideH', 'insideV']:
                side_el = tblBorders.find(qn(f'w:{side}'))
                if side_el is not None:
                    info['borders'][side] = {
                        'val': side_el.get(qn('w:val')),
                        'sz': side_el.get(qn('w:sz')),
                        'color': side_el.get(qn('w:color')),
                        'space': side_el.get(qn('w:space')),
                    }

        # Table cell margins (default)
        tblCellMar = tblPr.find(qn('w:tblCellMar'))
        if tblCellMar is not None:
            info['default_cell_margins'] = {}
            for side in ['top', 'bottom', 'left', 'right']:
                side_el = tblCellMar.find(qn(f'w:{side}'))
                if side_el is not None:
                    w_val = side_el.get(qn('w:w'))
                    info['default_cell_margins'][side] = twip_to_pt(int(w_val)) if w_val and w_val.isdigit() else None

        # Table look (style options)
        tblLook = tblPr.find(qn('w:tblLook'))
        if tblLook is not None:
            info['tblLook'] = {}
            for attr in ['val', 'firstRow', 'lastRow', 'firstColumn', 'lastColumn', 'noHBand', 'noVBand']:
                v = tblLook.get(qn(f'w:{attr}'))
                if v is not None:
                    info['tblLook'][attr] = v

    # Column widths from grid
    tblGrid = tbl.find(qn('w:tblGrid'))
    if tblGrid is not None:
        info['grid_cols'] = []
        for gridCol in tblGrid.findall(qn('w:gridCol')):
            w_val = gridCol.get(qn('w:w'))
            info['grid_cols'].append({
                'twip': w_val,
                'cm': twip_to_cm(int(w_val)) if w_val and w_val.isdigit() else None
            })

    # Row height
    info['row_heights'] = []
    for row in table.rows:
        trPr = row._tr.find(qn('w:trPr'))
        if trPr is not None:
            trHeight = trPr.find(qn('w:trHeight'))
            if trHeight is not None:
                h_val = trHeight.get(qn('w:val'))
                h_rule = trHeight.get(qn('w:hRule'))
                info['row_heights'].append({
                    'twip': h_val,
                    'cm': twip_to_cm(int(h_val)) if h_val and h_val.isdigit() else None,
                    'pt': twip_to_pt(int(h_val)) if h_val and h_val.isdigit() else None,
                    'hRule': h_rule
                })
            else:
                info['row_heights'].append(None)
        else:
            info['row_heights'].append(None)

        # Row banding/can't split
        if trPr is not None:
            cantSplit = trPr.find(qn('w:cantSplit'))
            if cantSplit is not None:
                if 'row_properties' not in info:
                    info['row_properties'] = {}
                info['row_properties'][f'row_{row._tr.index}'] = {'cantSplit': True}

    # Cells
    info['cells'] = []
    for row_idx, row in enumerate(table.rows):
        for col_idx, cell in enumerate(row.cells):
            cell_info = get_cell_info(cell)
            cell_info['row'] = row_idx
            cell_info['col'] = col_idx
            info['cells'].append(cell_info)

    return info


def get_section_info(section):
    """Extract detailed section info."""
    info = {}

    # Page size
    page_width = section.page_width
    page_height = section.page_height
    info['page_width'] = {
        'emu': page_width,
        'cm': emu_to_cm(page_width),
        'inches': round(page_width / 914400, 2) if page_width else None
    }
    info['page_height'] = {
        'emu': page_height,
        'cm': emu_to_cm(page_height),
        'inches': round(page_height / 914400, 2) if page_height else None
    }

    # Orientation
    info['orientation'] = 'LANDSCAPE' if section.orientation == WD_ORIENT.LANDSCAPE else 'PORTRAIT'

    # Margins
    info['margins'] = {
        'top': {'emu': section.top_margin, 'cm': emu_to_cm(section.top_margin)},
        'bottom': {'emu': section.bottom_margin, 'cm': emu_to_cm(section.bottom_margin)},
        'left': {'emu': section.left_margin, 'cm': emu_to_cm(section.left_margin)},
        'right': {'emu': section.right_margin, 'cm': emu_to_cm(section.right_margin)},
        'header': {'emu': section.header_distance, 'cm': emu_to_cm(section.header_distance)},
        'footer': {'emu': section.footer_distance, 'cm': emu_to_cm(section.footer_distance)},
        'gutter': {'emu': section.gutter, 'cm': emu_to_cm(section.gutter)},
    }

    # Columns
    sectPr = section._sectPr
    cols = sectPr.find(qn('w:cols'))
    if cols is not None:
        info['num_columns'] = cols.get(qn('w:num'))
        info['column_space'] = cols.get(qn('w:space'))
        info['column_sep'] = cols.get(qn('w:sep'))

    # Page number settings
    pgNumType = sectPr.find(qn('w:pgNumType'))
    if pgNumType is not None:
        info['page_numbering'] = {
            'fmt': pgNumType.get(qn('w:fmt')),
            'start': pgNumType.get(qn('w:start')),
        }

    # Line number settings
    lnNumType = sectPr.find(qn('w:lnNumType'))
    if lnNumType is not None:
        info['line_numbering'] = {
            'countBy': lnNumType.get(qn('w:countBy')),
            'start': lnNumType.get(qn('w:start')),
            'distance': lnNumType.get(qn('w:distance')),
        }

    # Page border
    pgBorders = sectPr.find(qn('w:pgBorders'))
    if pgBorders is not None:
        info['page_borders'] = {}
        for side in ['top', 'bottom', 'left', 'right']:
            side_el = pgBorders.find(qn(f'w:{side}'))
            if side_el is not None:
                info['page_borders'][side] = {
                    'val': side_el.get(qn('w:val')),
                    'sz': side_el.get(qn('w:sz')),
                    'color': side_el.get(qn('w:color')),
                    'space': side_el.get(qn('w:space')),
                }

    # Title page
    titlePg = sectPr.find(qn('w:titlePg'))
    info['title_page'] = titlePg is not None

    # Header reference
    header_ref = sectPr.find(qn('w:headerReference'))
    if header_ref is not None:
        info['header_reference'] = {
            'type': header_ref.get(qn('w:type')),
            'id': header_ref.get(qn('r:id')),
        }

    # Footer reference
    footer_ref = sectPr.find(qn('w:footerReference'))
    if footer_ref is not None:
        info['footer_reference'] = {
            'type': footer_ref.get(qn('w:type')),
            'id': footer_ref.get(qn('r:id')),
        }

    # Form protection
    formProt = sectPr.find(qn('w:formProt'))
    if formProt is not None:
        info['form_protection'] = True

    return info


def get_header_footer_info(hf, hf_type, section_idx):
    """Extract header or footer info."""
    if hf is None:
        return None

    info = {}
    info['type'] = hf_type
    info['section'] = section_idx
    info['paragraphs'] = []
    info['tables'] = []

    for para in hf.paragraphs:
        info['paragraphs'].append(get_paragraph_info(para))

    for idx, table in enumerate(hf.tables):
        info['tables'].append(get_table_info(table, idx))

    # Check for linked/linkedToPrevious
    info['linked_to_previous'] = hf.is_linked_to_previous

    return info


