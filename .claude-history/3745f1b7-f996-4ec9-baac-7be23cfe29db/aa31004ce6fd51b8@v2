function tr(text, opts = {}) {
  return new TextRun({ text, font: opts.font || FONT, size: opts.size || 21, bold: opts.bold || false });
}
function p(children, opts = {}) {
  const arr = Array.isArray(children) ? children : [tr(children)];
  return new Paragraph({ children: arr, alignment: opts.alignment, spacing: opts.spacing || { after: 60 }, indent: opts.indent });
}
function empty() { return new Paragraph({ children: [tr("")], spacing: { after: 40 } }); }
function heading(text) { return new Paragraph({ children: [tr(text, { bold: true, size: 26 })], spacing: { before: 200, after: 120 } }); }
function subheading(text) { return new Paragraph({ children: [tr(text, { bold: true, size: 24 })], spacing: { before: 120, after: 80 } }); }
function body(text, indent = true) { return new Paragraph({ children: [tr(text)], indent: indent ? { firstLine: 420 } : undefined, spacing: { after: 60 } }); }

const border = { style: BorderStyle.SINGLE, size: 1, color: "000000" };
const borders = { top: border, bottom: border, left: border, right: border };
const cm = { top: 60, bottom: 60, left: 100, right: 100 };
function cell(children, opts = {}) {
  return new TableCell({ borders, width: opts.width ? { size: opts.width, type: WidthType.DXA } : undefined, shading: opts.shading ? { fill: opts.shading, type: ShadingType.CLEAR } : undefined, margins: cm, verticalAlign: "center", children: Array.isArray(children) ? children : [children] });
}
function cellP(text, opts = {}) {
  return cell([new Paragraph({ children: [tr(text, { bold: opts.bold, size: opts.size || 20 })], alignment: opts.alignment || AlignmentType.CENTER, spacing: { after: 0 } })], opts);
}

