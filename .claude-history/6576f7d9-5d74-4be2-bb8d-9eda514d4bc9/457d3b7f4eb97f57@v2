const noBorder = { style: BorderStyle.NONE, size: 0 };
const noBorders = { top: noBorder, bottom: noBorder, left: noBorder, right: noBorder };
const cellMargins = { top: 60, bottom: 60, left: 80, right: 80 };
const cellMarginsWide = { top: 80, bottom: 80, left: 120, right: 120 };

function headingCell(text, width, opts = {}) {
    return new TableCell({
        borders,
        width: { size: width, type: WidthType.DXA },
        shading: { fill: opts.fill || "D5E8F0", type: ShadingType.CLEAR },
        margins: cellMarginsWide,
        verticalAlign: VerticalAlign.CENTER,
        children: [new Paragraph({
            alignment: opts.align || AlignmentType.CENTER,
            children: [new TextRun({ text, bold: true, font: "Arial", size: opts.size || 20 })]
        })]
    });
}

function dataCell(text, width, opts = {}) {
    return new TableCell({
        borders,
        width: { size: width, type: WidthType.DXA },
        margins: cellMarginsWide,
        verticalAlign: VerticalAlign.CENTER,
        children: [new Paragraph({
            alignment: opts.align || AlignmentType.CENTER,
            children: [new TextRun({ text: String(text || ''), font: "Arial", size: opts.size || 18, bold: !!opts.bold })]
        })]
    });
}

function emptyPara(text, opts = {}) {
    return new Paragraph({
        spacing: { before: opts.before || 0, after: opts.after || 0 },
        alignment: opts.align || AlignmentType.LEFT,
        children: [new TextRun({ text: text || '', font: "Arial", size: opts.size || 22, bold: !!opts.bold, ...(opts.italics ? { italics: true } : {}) })]
    });
}

function lineSpace(before, after) {
    return new Paragraph({ spacing: { before, after }, children: [] });
}

function sectionTitle(text) {
    return new Paragraph({
        spacing: { before: 200, after: 100 },
        alignment: AlignmentType.LEFT,
        children: [new TextRun({ text, font: "Arial", size: 24, bold: true })]
    });
}

