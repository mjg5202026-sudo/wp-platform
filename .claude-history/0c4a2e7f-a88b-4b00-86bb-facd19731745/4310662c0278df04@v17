    p = doc.add_paragraph(); p.alignment = WD_ALIGN_PARAGRAPH.JUSTIFY; run = p.add_run(text); sf(run, ea='宋体_GB2312', sz=16)
def B(doc, text):
    p = doc.add_paragraph(); p.alignment = WD_ALIGN_PARAGRAPH.JUSTIFY; pf = p.paragraph_format; pf.first_line_indent = Emu(444 * 914400 // 1000); run = p.add_run(text); sf(run, ea='宋体_GB2312', sz=16)

def SH(cell, color):
    sh = OxmlElement('w:shd'); sh.set(qn('w:val'), 'clear'); sh.set(qn('w:color'), 'auto'); sh.set(qn('w:fill'), color); cell._tc.get_or_add_tcPr().append(sh)
def VC(cell):
    tcPr = cell._tc.get_or_add_tcPr(); va = tcPr.find(qn('w:vAlign'))
    if va is None: va = OxmlElement('w:vAlign'); tcPr.append(va); va.set(qn('w:val'), 'center')
def BN(cell):
    tcPr = cell._tc.get_or_add_tcPr(); bd = OxmlElement('w:tcBorders')
    for e in ['top','left','bottom','right']:
        el = OxmlElement(f'w:{e}'); el.set(qn('w:val'), 'none'); el.set(qn('w:sz'), '0'); el.set(qn('w:color'), 'auto'); bd.append(el)
    tcPr.append(bd)
def TC(cell, text, sz=11, b=False, shd=None):
    cell.text = ''
    if shd: SH(cell, shd)
    VC(cell); p = cell.paragraphs[0]; p.alignment = WD_ALIGN_PARAGRAPH.CENTER; run = p.add_run(text); sf(run, sz=sz, b=b); BN(cell)
def CAP(doc, text):
    p = doc.add_paragraph(); p.alignment = WD_ALIGN_PARAGRAPH.CENTER; pf = p.paragraph_format; pf.space_before = Pt(8); pf.space_after = Pt(8); run = p.add_run(text); sf(run, sz=12)
def TBL(doc, hds, rows, wd=None, sz=11):
    t = doc.add_table(rows=1+len(rows), cols=len(hds)); t.alignment = WD_TABLE_ALIGNMENT.CENTER
    if wd:
        for row in t.rows:
            for i, w in enumerate(wd): row.cells[i].width = Emu(w)
    for i, h in enumerate(hds): TC(t.rows[0].cells[i], h, sz=sz, b=True, shd='B5C7EA')
    for ri, rd in enumerate(rows):
        for ci, v in enumerate(rd): TC(t.rows[ri+1].cells[ci], str(v), sz=sz)
    return t

