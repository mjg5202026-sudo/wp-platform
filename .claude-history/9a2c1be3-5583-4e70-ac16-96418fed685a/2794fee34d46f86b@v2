txt = '\n'.join([p.text for p in doc.paragraphs if p.text.strip()])

problems = ['责任划分', 'Jiangsu Xinxin', '即PT']
for p in problems:
    if p in txt:
        print(f'  WARNING: "{p}" still present!')
