def load_workbook(file_path: str):
    """?? Excel ?????????"""
    ext = os.path.splitext(file_path)[1].lower()
    if ext == ".xlsx":
        return openpyxl.load_workbook(file_path, data_only=True)
    elif ext == ".xls":
        import xlrd
        return xlrd.open_workbook(file_path)
    else:
        raise ValueError(f"????????: {ext}")


