def add_body(doc, text):
    """正文：宋体_GB2312 16pt 两端对齐 首行缩进0.444in"""
    p = doc.add_paragraph()
    p.alignment = WD_ALIGN_PARAGRAPH.JUSTIFY
    pf = p.paragraph_format
    pf.first_line_indent = Emu(444 * 914400 // 1000)  # 0.444 inch in EMU
    pf.space_before = Pt(0)
    pf.space_after = Pt(0)
    run = p.add_run(text)
    set_font(run, east_asia='宋体_GB2312', size=16)
    return p

def set_cell_shading(cell, color):
    """设置单元格底纹"""
    shading = OxmlElement('w:shd')
    shading.set(qn('w:val'), 'clear')
    shading.set(qn('w:color'), 'auto')
    shading.set(qn('w:fill'), color)
    cell._tc.get_or_add_tcPr().append(shading)

def set_cell_vertical_center(cell):
    """垂直居中"""
    tc = cell._tc
    tcPr = tc.get_or_add_tcPr()
    vAlign = tcPr.find(qn('w:vAlign'))
    if vAlign is None:
        vAlign = OxmlElement('w:vAlign')
        tcPr.append(vAlign)
    vAlign.set(qn('w:val'), 'center')

def set_border_none(cell):
    """移除单元格边框"""
    tc = cell._tc
    tcPr = tc.get_or_add_tcPr()
    borders = OxmlElement('w:tcBorders')
    for edge in ['top', 'left', 'bottom', 'right']:
        el = OxmlElement(f'w:{edge}')
        el.set(qn('w:val'), 'none')
        el.set(qn('w:sz'), '0')
        el.set(qn('w:color'), 'auto')
        borders.append(el)
    tcPr.append(borders)

def add_table_header_cell(cell, text, width_emu=None):
    """设置表头单元格：宋体11pt 加粗 居中 蓝色背景#B5C7EA"""
    cell.text = ''
    set_cell_shading(cell, 'B5C7EA')
    set_cell_vertical_center(cell)
    if width_emu:
        cell.width = Emu(width_emu)
    p = cell.paragraphs[0]
    p.alignment = WD_ALIGN_PARAGRAPH.CENTER
    # 段前段后为0
    pf = p.paragraph_format
    pf.space_before = Pt(0)
    pf.space_after = Pt(0)
    run = p.add_run(text)
    set_font(run, size=11, bold=True)
    # 无边框
    set_border_none(cell)

def add_table_data_cell(cell, text, width_emu=None, font_size=11):
    """设置数据单元格：宋体11pt 居中"""
    cell.text = ''
    set_cell_vertical_center(cell)
    if width_emu:
        cell.width = Emu(width_emu)
    p = cell.paragraphs[0]
    p.alignment = WD_ALIGN_PARAGRAPH.CENTER
    pf = p.paragraph_format
    pf.space_before = Pt(0)
    pf.space_after = Pt(0)
    run = p.add_run(text)
    set_font(run, size=font_size)
    set_border_none(cell)

def add_table_caption(doc, text):
    """表格标题：宋体 12pt 居中"""
    p = doc.add_paragraph()
    p.alignment = WD_ALIGN_PARAGRAPH.CENTER
    pf = p.paragraph_format
    pf.space_before = Pt(8)
    pf.space_after = Pt(8)
    run = p.add_run(text)
    set_font(run, size=12)
    return p

def build_table(doc, headers, rows, col_widths_emu=None, font_size=11):
    """构建无边框表格"""
    table = doc.add_table(rows=1 + len(rows), cols=len(headers))
    table.alignment = WD_TABLE_ALIGNMENT.CENTER
    # 设置列宽
    if col_widths_emu:
        for row in table.rows:
            for i, w in enumerate(col_widths_emu):
                row.cells[i].width = Emu(w)
    # 表头
    for i, h in enumerate(headers):
        add_table_header_cell(table.rows[0].cells[i], h,
                               col_widths_emu[i] if col_widths_emu else None)
    # 数据行
    for r_idx, row_data in enumerate(rows):
        for c_idx, val in enumerate(row_data):
            size = font_size
            # 表9-10用12pt
            add_table_data_cell(table.rows[r_idx + 1].cells[c_idx], str(val),
                                col_widths_emu[c_idx] if col_widths_emu else None,
                                font_size=size)
    return table

