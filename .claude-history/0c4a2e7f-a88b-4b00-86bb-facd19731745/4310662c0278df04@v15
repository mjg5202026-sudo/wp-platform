# ========== 排版工具函数（与原文一致） ==========
def set_font(run, font_name='宋体', east_asia='宋体', size=16, bold=False):
    run.font.size = Pt(size)
    run.bold = bold
    rPr = run._element.find(qn('w:rPr'))
    if rPr is None:
        rPr = OxmlElement('w:rPr')
        run._element.insert(0, rPr)
    rFonts = rPr.find(qn('w:rFonts'))
    if rFonts is None:
        rFonts = OxmlElement('w:rFonts')
        rPr.insert(0, rFonts)
    rFonts.set(qn('w:ascii'), font_name)
    rFonts.set(qn('w:hAnsi'), font_name)
    rFonts.set(qn('w:eastAsia'), east_asia)

def add_title(doc, text):
    p = doc.add_paragraph(); p.alignment = WD_ALIGN_PARAGRAPH.CENTER
    run = p.add_run(text); set_font(run, '方正小标宋简体', '方正小标宋简体', 24)
    return p

def add_subtitle(doc, text):
    p = doc.add_paragraph(); p.alignment = WD_ALIGN_PARAGRAPH.CENTER
    run = p.add_run(text); set_font(run, size=16)
    return p

def add_h1(doc, text):
    p = doc.add_paragraph(); p.alignment = WD_ALIGN_PARAGRAPH.JUSTIFY
    run = p.add_run(text); set_font(run, size=16, bold=False)
    p.paragraph_format.space_before = Pt(12)
    return p

def add_h2(doc, text):
    p = doc.add_paragraph(); p.alignment = WD_ALIGN_PARAGRAPH.JUSTIFY
    run = p.add_run(text); set_font(run, east_asia='宋体_GB2312', size=16, bold=True)
    return p

def add_h3(doc, text):
    p = doc.add_paragraph(); p.alignment = WD_ALIGN_PARAGRAPH.JUSTIFY
    run = p.add_run(text); set_font(run, east_asia='宋体_GB2312', size=16, bold=False)
    return p

def add_body(doc, text):
    p = doc.add_paragraph(); p.alignment = WD_ALIGN_PARAGRAPH.JUSTIFY
    pf = p.paragraph_format
    pf.first_line_indent = Emu(444 * 914400 // 1000)
    run = p.add_run(text); set_font(run, east_asia='宋体_GB2312', size=16)
    return p

def set_cell_shading(cell, color):
    shading = OxmlElement('w:shd')
    shading.set(qn('w:val'), 'clear'); shading.set(qn('w:color'), 'auto'); shading.set(qn('w:fill'), color)
    cell._tc.get_or_add_tcPr().append(shading)

def set_cell_vertical_center(cell):
    tcPr = cell._tc.get_or_add_tcPr()
    vAlign = tcPr.find(qn('w:vAlign'))
    if vAlign is None:
        vAlign = OxmlElement('w:vAlign'); tcPr.append(vAlign)
    vAlign.set(qn('w:val'), 'center')

def set_border_none(cell):
    tcPr = cell._tc.get_or_add_tcPr()
    borders = OxmlElement('w:tcBorders')
    for edge in ['top','left','bottom','right']:
        el = OxmlElement(f'w:{edge}')
        el.set(qn('w:val'), 'none'); el.set(qn('w:sz'), '0'); el.set(qn('w:color'), 'auto')
        borders.append(el)
    tcPr.append(borders)

def add_tc(cell, text, sz=11, bold=False, shading=None):
    cell.text = ''
    if shading: set_cell_shading(cell, shading)
    set_cell_vertical_center(cell)
    p = cell.paragraphs[0]; p.alignment = WD_ALIGN_PARAGRAPH.CENTER
    run = p.add_run(text); set_font(run, size=sz, bold=bold)
    set_border_none(cell)

def add_caption(doc, text):
    p = doc.add_paragraph(); p.alignment = WD_ALIGN_PARAGRAPH.CENTER
    pf = p.paragraph_format; pf.space_before = Pt(8); pf.space_after = Pt(8)
    run = p.add_run(text); set_font(run, size=12)

def build_table(doc, headers, rows, widths=None, sz=11):
    t = doc.add_table(rows=1+len(rows), cols=len(headers))
    t.alignment = WD_TABLE_ALIGNMENT.CENTER
    if widths:
        for row in t.rows:
            for i, w in enumerate(widths): row.cells[i].width = Emu(w)
    for i, h in enumerate(headers):
        add_tc(t.rows[0].cells[i], h, sz=sz, bold=True, shading='B5C7EA')
    for ri, rd in enumerate(rows):
        for ci, v in enumerate(rd):
            add_tc(t.rows[ri+1].cells[ci], str(v), sz=sz)
    return t

