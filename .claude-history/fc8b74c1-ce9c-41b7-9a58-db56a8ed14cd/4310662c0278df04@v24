def SH(cell, color):
    sh = OxmlElement('w:shd'); sh.set(qn('w:val'), 'clear'); sh.set(qn('w:color'), 'auto'); sh.set(qn('w:fill'), color); cell._tc.get_or_add_tcPr().append(sh)
def VC(cell):
    tcPr = cell._tc.get_or_add_tcPr()
    # 清除已有的vAlign设置
    for child in list(tcPr):
        if child.tag.endswith('vAlign'):
            tcPr.remove(child)
    va = OxmlElement('w:vAlign')
    va.set(qn('w:val'), 'center')
    tcPr.append(va)
def BN(cell):
    tcPr = cell._tc.get_or_add_tcPr(); bd = OxmlElement('w:tcBorders')
    for e in ['top','left','bottom','right']:
        el = OxmlElement(f'w:{e}'); el.set(qn('w:val'), 'none'); el.set(qn('w:sz'), '0'); el.set(qn('w:color'), 'auto'); bd.append(el)
    tcPr.append(bd)
def TC(cell, text, sz=11, b=False, shd=None):
    cell.text = ''
    if shd: SH(cell, shd)
    p = cell.paragraphs[0]; p.alignment = WD_ALIGN_PARAGRAPH.CENTER
    pf = p.paragraph_format; pf.space_before = Pt(0); pf.space_after = Pt(0)
    run = p.add_run(text); sf(run, sz=sz, b=b); BN(cell)
    VC(cell)  # 最后设置垂直居中
def CAP(doc, text):
    p = doc.add_paragraph(); p.alignment = WD_ALIGN_PARAGRAPH.CENTER; pf = p.paragraph_format; pf.space_before = Pt(8); pf.space_after = Pt(8); run = p.add_run(text); sf(run, fn='宋体', ea='宋体', sz=12)
def TBL(doc, hds, rows, wd=None, sz=11):
    t = doc.add_table(rows=1+len(rows), cols=len(hds)); t.alignment = WD_TABLE_ALIGNMENT.CENTER
    ncols = len(hds)
    # 表格总宽度15cm = 15 * 567 = 8505 twips
    tbl_width_twips = int(15 * 1440 / 2.54)
    t.autofit = False
    tbl_pr = t._tbl.tblPr
    if tbl_pr is None:
        tbl_pr = OxmlElement('w:tblPr')
        t._tbl.insert(0, tbl_pr)
    else:
        # 移除已有宽度设置
        for child in list(tbl_pr):
            if child.tag.endswith('tblW'):
                tbl_pr.remove(child)
    tbl_w = OxmlElement('w:tblW')
    tbl_w.set(qn('w:w'), str(tbl_width_twips))
    tbl_w.set(qn('w:type'), 'dxa')
    tbl_pr.append(tbl_w)
    for row in t.rows:
        for cell in row.cells:
            cell.width = Cm(15 / ncols)
    for i, h in enumerate(hds): TC(t.rows[0].cells[i], h, sz=sz, b=True, shd='B5C7EA')
    for ri, rd in enumerate(rows):
        for ci, v in enumerate(rd): TC(t.rows[ri+1].cells[ci], str(v), sz=sz)
        # 每行高度1cm
        tr = t.rows[ri+1]._tr
        trPr = tr.find(qn('w:trPr'))
        if trPr is None:
            trPr = OxmlElement('w:trPr')
            tr.insert(0, trPr)
        trHeight = OxmlElement('w:trHeight')
        trHeight.set(qn('w:val'), str(int(1440 / 2.54)))  # 1cm in twips
        trHeight.set(qn('w:hRule'), 'atLeast')
        trPr.append(trHeight)
    # 表头也设置高度1cm
    tr0 = t.rows[0]._tr
    trPr0 = tr0.find(qn('w:trPr'))
    if trPr0 is None:
        trPr0 = OxmlElement('w:trPr')
        tr0.insert(0, trPr0)
    trH0 = OxmlElement('w:trHeight')
    trH0.set(qn('w:val'), str(int(1440 / 2.54)))
    trH0.set(qn('w:hRule'), 'atLeast')
    trPr0.append(trH0)
    return t

