// ===== 工具函数 =====
function tr(text, opts = {}) {
  return new TextRun({
    text,
    font: opts.font || FONT_BODY,
    size: opts.size || SZ_BODY,
    bold: opts.bold || false,
    ...(opts.color ? { color: opts.color } : {}),
  });
}

function p(children, opts = {}) {
  return new Paragraph({
    children: Array.isArray(children) ? children : [tr(children)],
    alignment: opts.alignment,
    spacing: { line: LINE_BODY, lineRule: "exact", ...(opts.spacing || {}) },
    indent: opts.indent,
    ...(opts.keepNext ? { keepNext: true } : {}),
    ...(opts.pageBreakBefore ? { pageBreakBefore: true } : {}),
  });
}

function empty(lines = 1) {
  const arr = [];
  for (let i = 0; i < lines; i++) {
    arr.push(p([tr("", { size: 10 })]));
  }
  return arr;
}

function titleP(text) {
  return p([tr(text, { font: FONT_TITLE, size: SZ_TITLE })], {
    alignment: AlignmentType.CENTER,
    spacing: { line: LINE_TITLE, lineRule: "exact", before: 200, after: 200 },
  });
}

function h1(text) {
  return p([tr(text, { font: FONT_H1, size: SZ_BODY, bold: true })], {
    spacing: { line: LINE_BODY, lineRule: "exact", before: 200 },
    keepNext: true,
  });
}

function h2(text) {
  return p([tr(text, { font: FONT_H2, size: SZ_BODY, bold: true })], {
    spacing: { line: LINE_BODY, lineRule: "exact", before: 100 },
    keepNext: true,
  });
}

function bodyLine(text) {
  return p([tr(text)], { indent: { firstLine: INDENT_2 } });
}

function biBody(zh, id) {
  return p([
    tr(zh),
  ], { indent: { firstLine: INDENT_2 }, spacing: { line: LINE_BODY, lineRule: "exact", after: 20 } });
}

function biBody2(zh, id) {
  return p([
    tr(id, { font: FONT_EN }),
  ], { indent: { firstLine: INDENT_2 }, spacing: { line: LINE_BODY, lineRule: "exact" } });
}

