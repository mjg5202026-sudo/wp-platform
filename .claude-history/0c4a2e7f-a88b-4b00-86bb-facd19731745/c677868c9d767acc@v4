    # 对齐方式
    if p.alignment == WD_ALIGN_PARAGRAPH.CENTER:
        jc = OxmlElement('w:jc'); jc.set(qn('w:val'), 'center'); pPr.append(jc)
    elif p.alignment == WD_ALIGN_PARAGRAPH.JUSTIFY:
        jc = OxmlElement('w:jc'); jc.set(qn('w:val'), 'both'); pPr.append(jc)

    # 首行缩进
    if p.paragraph_format.first_line_indent:
        ind = OxmlElement('w:ind')
        ind.set(qn('w:firstLine'), str(int(p.paragraph_format.first_line_indent.emu or 0)))
        pPr.append(ind)

    # 行距
    ls = p.paragraph_format.line_spacing
    if ls:
        spacing = OxmlElement('w:spacing')
        if ls == 1.5:
            spacing.set(qn('w:line'), '360')
            spacing.set(qn('w:lineRule'), 'auto')
        elif ls == 1.0:
            spacing.set(qn('w:line'), '240')
            spacing.set(qn('w:lineRule'), 'auto')
        pPr.append(spacing)

    # 段间距
    sb = p.paragraph_format.space_before
    sa = p.paragraph_format.space_after
    if sb or sa:
        spacing = pPr.find(qn('w:spacing'))
        if spacing is None:
            spacing = OxmlElement('w:spacing'); pPr.append(spacing)
        if sb: spacing.set(qn('w:before'), str(int(sb.pt * 20)))
        if sa: spacing.set(qn('w:after'), str(int(sa.pt * 20)))

    # 添加运行（Times New Roman 14pt）
