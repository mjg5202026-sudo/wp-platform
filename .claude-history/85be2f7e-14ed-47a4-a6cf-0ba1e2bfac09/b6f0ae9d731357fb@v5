# -*- coding: utf-8 -*-
import xlrd, sys, io
from collections import defaultdict

sys.stdout = io.TextIOWrapper(sys.stdout.buffer, encoding='utf-8')

wb = xlrd.open_workbook(r'D:\soft\work-flow\wp-platform\data\templates\影响作业率因素统计 2026(4).xls')
sh = wb.sheet_by_index(0)
datemode = wb.datemode

def hex_id(s):
    return s.encode('utf-8').hex()

def should_exclude_reason(reason_str):
    h = hex_id(reason_str)
    if h == 'e7949fe4baa7e7bb84e7bb87': return True
    if h == 'e8aea1e58892e680a7e6a380e4bfae': return True
    if 'e4bf9de99a9c' in h: return True
    if 'e8bda6e8be86' in h: return True
    return False

def is_dianlu(line_str):
    return hex_id(line_str).endswith('e794b5e78289')

def is_limo(factor_str):
    return 'e7ab8be7a3a8' in hex_id(factor_str)

def line_num(line_str):
    h = hex_id(line_str)
    for n, p in [(1,'31'),(2,'32'),(3,'33')]:
        if h.startswith(p): return n
    return 0

# ==== 读取数据 ====
records = []
for r in range(1, sh.nrows):
    v = sh.cell_value(r, 0)
    if isinstance(v, (int, float)) and v > 40000:
        t = xlrd.xldate_as_tuple(v, datemode)
        if t[1] == 6 and t[0] == 2026:
            line = str(sh.cell_value(r, 3)).strip()
            reason = str(sh.cell_value(r, 9)).strip()
            factor = str(sh.cell_value(r, 4)).strip()
            mins = sh.cell_value(r, 7)
            ln = line_num(line)
            if 1 <= ln <= 3 and isinstance(mins, (int, float)) and mins > 0:
                if not should_exclude_reason(reason):
                    records.append({
                        'day': t[2], 'ln': ln,
                        'factor': factor, 'mins': mins,
                        'is_dianlu': is_dianlu(line),
                        'is_limo': is_limo(factor),
                    })

# ==== 判断哪些日期有立磨事件 ====
limo_days_by_line = defaultdict(set)
for rec in records:
    if rec['is_limo']:
        limo_days_by_line[rec['ln']].add(rec['day'])

# ==== 重新分类 ====
# 原则：立磨当天发生的所有"其他检修活动" → 归入立磨影响
# 因为生产线已因立磨停机，这些检修没造成额外停机

# 按(日期, 线号, 因素)分组
groups = defaultdict(list)
for rec in records:
    key = (rec['day'], rec['ln'], rec['factor'])
    groups[key].append(rec)

line_own = {1:0.0, 2:0.0, 3:0.0}
line_limo = {1:0.0, 2:0.0, 3:0.0}
factor_own = defaultdict(float)
factor_limo = defaultdict(float)

for (day, ln, factor), recs in groups.items():
    has_limo = any(r['is_limo'] for r in recs)
    on_limo_day = day in limo_days_by_line[ln]

    if has_limo:
        # 立磨事件：取电炉MAX
        dianlu_mins = [r['mins'] for r in recs if r['is_dianlu']]
        val = max(dianlu_mins) if dianlu_mins else 0
        line_limo[ln] += val
        factor_limo[factor] += val
    elif on_limo_day:
        # 非立磨事件，但发生在立磨当天 → 归入立磨
        # 因为生产线已因立磨停机，这些检修没造成额外损失
        val = max(r['mins'] for r in recs)
        line_limo[ln] += val
        factor_limo[factor] += val
    else:
        # 真正的产线自身故障
        val = max(r['mins'] for r in recs)
        line_own[ln] += val
        factor_own[factor] += val

# ==== 输出 ====
DAYS = 29
LINE_MIN = DAYS * 24 * 60

total_own = sum(line_own.values())
total_limo = sum(line_limo.values())
total_all = total_own + total_limo

print("=" * 75)
print("  6月生产线故障率分析（立磨期间检修归入立磨）")
print("=" * 75)
print(f"  原则: 立磨故障导致产线停机后，期间所有检修归入立磨影响")
print(f"  目的: 反映真实额外停机，而非'顺便'做的检修")
print()

print(f"  期间: 6/1-6/29 | 总可用: {DAYS*24*3} 线·小时")
print()

print("─" * 75)
print(f"  {'线':>4} {'自身故障':>18} {'立磨(含同期检修)':>22} {'综合停机':>14} {'自身故障率':>10} {'综合故障率':>10}")
print("─" * 75)
for ln in [1,2,3]:
    own, limo = line_own[ln], line_limo[ln]
    total_ln = own + limo
    or_ = own / LINE_MIN * 100
    tr_ = total_ln / LINE_MIN * 100
    print(f"  {ln}#线: {own:>8.0f}min ({own/60:>5.1f}h)  {limo:>8.0f}min ({limo/60:>5.1f}h)  {total_ln:>10.0f}min ({total_ln/60:>5.1f}h)  {or_:>8.2f}%  {tr_:>8.2f}%")
print("─" * 75)
avg_own = total_own / (LINE_MIN*3) * 100
avg_all = total_all / (LINE_MIN*3) * 100
print(f"  {'合计':>4} {total_own:>8.0f}min ({total_own/60:>5.1f}h)  {total_limo:>8.0f}min ({total_limo/60:>5.1f}h)  {total_all:>10.0f}min ({total_all/60:>5.1f}h)  {avg_own:>8.2f}%  {avg_all:>8.2f}%")
print()
print(f"  ▲ 立磨(含同期检修)总影响: {total_limo:.0f} min ({total_limo/60:.1f} h)")
print(f"  ▲ 产线自身平均故障率: {avg_own:.2f}%")
print(f"  ★ 平均综合故障率: {avg_all:.2f}%")
print()

# ==== TOP 10 ====
all_factors = defaultdict(float)
for f, v in factor_own.items(): all_factors[f] += v
for f, v in factor_limo.items(): all_factors[f] += v

ranked = sorted(all_factors.items(), key=lambda x: -x[1])

print("影响时间最长的10项因素:")
print("─" * 100)
print(f"  {'#':>3} {'因素描述':<52} {'类型':<6} {'停机(min)':>10} {'小时':>8} {'占比':>7}")
print("─" * 100)
for i, (factor, mins) in enumerate(ranked[:10], 1):
    # Determine type
    typ = "公辅"
    if not is_limo(factor):
        # Check if this was reclassified (happened on limo day)
        typ = "公辅(含检修)"  # most should be limo-related now
        # Actually let's check - use a simpler label
        typ = "产线"
        # Check if this factor occurred on a non-limo day
        for (day, ln, fac), _ in groups.items():
            if fac == factor and day not in limo_days_by_line[ln]:
                typ = "产线"
                break
        else:
            typ = "公辅"

    # Better type labeling
    if is_limo(factor):
        typ = "公辅-立磨"
    else:
        # Check if this factor appears in limo-day groups
        appears_on_limo_day = False
        for (day, ln, fac), _ in groups.items():
            if fac == factor and day in limo_days_by_line[ln]:
                appears_on_limo_day = True
                break
        if appears_on_limo_day:
            typ = "公辅(含检修)"
        else:
            typ = "产线自身"

    disp = factor if len(factor) <= 48 else factor[:45] + "..."
    print(f"  {i:>3} {disp:<52} {typ:<10} {mins:>10.0f} {mins/60:>8.1f} {mins/total_all*100:>6.1f}%")
print("─" * 100)
t10 = sum(m for _, m in ranked[:10])
print(f"  {'TOP 10 合计':>66} {t10:>10.0f} {t10/60:>8.1f} {t10/total_all*100:>6.1f}%")
print()

# ==== 对比：调整前后 ====
print("=" * 75)
print("  对比：调整前(立磨->电炉) vs 调整后(同期检修归入立磨)")
print("=" * 75)
# Previous numbers (from before this adjustment)
prev_own = {1:567, 2:3965, 3:1669}
prev_limo = {1:2816, 2:2093, 3:720}
print()
print(f"  {'线':>4} {'调整前-自身':>14} {'调整前-立磨':>14} {'→':>4} {'调整后-自身':>14} {'调整后-立磨':>14}")
print("─" * 65)
for ln in [1,2,3]:
    print(f"  {ln}#线: {prev_own[ln]:>8.0f}min ({prev_own[ln]/60:>4.1f}h)  {prev_limo[ln]:>8.0f}min ({prev_limo[ln]/60:>4.1f}h)  →  {line_own[ln]:>8.0f}min ({line_own[ln]/60:>4.1f}h)  {line_limo[ln]:>8.0f}min ({line_limo[ln]/60:>4.1f}h)")
print("─" * 65)
print(f"  原综合故障率: {(sum(prev_own.values())+sum(prev_limo.values()))/(LINE_MIN*3)*100:.2f}%")
print(f"  现综合故障率: {avg_all:.2f}%")
