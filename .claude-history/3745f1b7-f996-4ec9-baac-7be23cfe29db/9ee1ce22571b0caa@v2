}

function p(children, opts) {
  opts = opts || {};
  var arr = Array.isArray(children) ? children : [tr(children)];
  var so = { line: LB, lineRule: "exact" };
  if (opts.sp) Object.assign(so, opts.sp);
  var po = { children: arr, spacing: so };
  if (opts.al) po.alignment = opts.al;
  if (opts.ind) po.indent = opts.ind;
  if (opts.kn) po.keepNext = true;
  return new PG(po);
}

