# -*- coding: utf-8 -*-
"""
故障率分析引擎 - 命令行入口

用法:
    # 月报
    python -m backend.analysis.cli --month 6 --year 2026

    # 指定 Excel 文件
    python -m backend.analysis.cli --month 6 --year 2026 --file "data/templates/xxx.xls"

    # 自定义日期范围
    python -m backend.analysis.cli --start 2026-06-01 --end 2026-06-29

    # 周报
    python -m backend.analysis.cli --start 2026-06-22 --end 2026-06-28

    # 季度
    python -m backend.analysis.cli --year 2026 --quarter 2

    # 半年 / 全年
    python -m backend.analysis.cli --year 2026 --period half_yearly
    python -m backend.analysis.cli --year 2026 --period yearly

    # JSON 输出（用于其他程序调用）
    python -m backend.analysis.cli --month 6 --year 2026 --output json

    # 简短输出
    python -m backend.analysis.cli --month 6 --year 2026 --output short
"""

import argparse
import json
import sys
import os
from datetime import date, datetime
from typing import Optional


def get_default_excel_path() -> str:
    """获取默认Excel文件路径"""
    # 检测多个可能的路径
    candidates = [
        # 相对于 wp-platform 根目录
        os.path.join("data", "templates"),
        # 相对于当前目录
        os.path.join(os.getcwd(), "data", "templates"),
        # 相对于脚本所在目录（backend/analysis/）
        os.path.join(os.path.dirname(os.path.dirname(__file__)), "..", "data", "templates"),
    ]

    # 统一用绝对路径
    resolved = []
    for c in candidates:
        if os.path.isdir(c):
            resolved.append(c)
        abs_p = os.path.abspath(c)
        if os.path.isdir(abs_p) and abs_p not in resolved:
            resolved.append(abs_p)

    # 查找匹配的文件
    for d in resolved:
        for f in sorted(os.listdir(d)):
            if "影响作业率" in f and (f.endswith('.xls') or f.endswith('.xlsx')):
                return os.path.join(d, f)

    return ""


def parse_args(argv=None):
    """解析命令行参数"""
    p = argparse.ArgumentParser(
        description="故障率分析工具 - 支持周/月/季/半年/年报",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
使用示例:
  python -m backend.analysis.cli --month 6 --year 2026
  python -m backend.analysis.cli --start 2026-06-01 --end 2026-06-29
  python -m backend.analysis.cli --year 2026 --quarter 2
  python -m backend.analysis.cli --year 2026 --period yearly --output json
        """,
    )

    # 数据源
    p.add_argument("--file", "-f", default="",
                    help="Excel文件路径（默认自动查找）")

    # 时间范围（方式一：指定年月）
    p.add_argument("--year", "-y", type=int, default=None,
                    help="年份，如 2026")
    p.add_argument("--month", "-m", type=int, default=None,
                    help="月份，1-12")

    # 时间范围（方式二：季度）
    p.add_argument("--quarter", "-q", type=int, default=None,
                    help="季度，1-4（需同时指定 --year）")

    # 时间范围（方式三：自定义日期）
    p.add_argument("--start", type=str, default=None,
                    help="开始日期，YYYY-MM-DD")
    p.add_argument("--end", type=str, default=None,
                    help="结束日期，YYYY-MM-DD")

    # 时间范围（方式四：周期类型）
    p.add_argument("--period", "-p", type=str, default=None,
                    choices=["weekly", "monthly", "quarterly",
                             "half_yearly", "yearly"],
                    help="周期类型（需同时指定 --year）")

    # 输出
    p.add_argument("--output", "-o", type=str, default="console",
                    choices=["console", "json", "short"],
                    help="输出格式（默认 console）")

    # 产线配置
    p.add_argument("--lines", type=str, default="1,2,3",
                    help="运行产线（默认 1,2,3）")

    # Top N
    p.add_argument("--top", type=int, default=10,
                    help="显示Top N因素（默认10）")

    args = p.parse_args(argv)

    # 校验参数
    if not any([args.month, args.start, args.end, args.quarter, args.period]):
        p.error("请指定时间范围：--month, --start/--end, --quarter 或 --period")

    return args


def resolve_date_range(args) -> tuple:
    """解析时间范围，返回 (start_date, end_date, days, label)"""
    import calendar

    today = date.today()

    # 方式一：指定年月（月报）
    if args.month and args.year:
        last_day = calendar.monthrange(args.year, args.month)[1]
        start = date(args.year, args.month, 1)
        end = date(args.year, args.month, last_day)
        # 对于当前月份，限制到今天
        if args.year == today.year and args.month == today.month:
            end = today
        days = (end - start).days + 1
        return start, end, days, "%d年%d月" % (args.year, args.month)

    # 方式二：季度
    if args.quarter and args.year:
        q_start_month = {1: 1, 2: 4, 3: 7, 4: 10}[args.quarter]
        q_end_month = {1: 3, 2: 6, 3: 9, 4: 12}[args.quarter]
        start = date(args.year, q_start_month, 1)
        last_day = calendar.monthrange(args.year, q_end_month)[1]
        end = date(args.year, q_end_month, last_day)
        if end > today:
            end = today
        days = (end - start).days + 1
        return start, end, days, "%d年第%d季度" % (args.year, args.quarter)

    # 方式三：周期类型
    if args.period and args.year:
        if args.period == "weekly":
            # 默认使用最近一周
            end = today
            start = date(end.year, end.month, end.day - 6)
            label = "%s 周报" % start.isoformat()

        elif args.period == "monthly":
            # 最近一个月
            end = today
            py = today.year - 1 if today.month == 1 else today.year
            pm = 12 if today.month == 1 else today.month - 1
            start = date(py, pm, today.day)
            label = "%s 月报" % start.strftime("%Y-%m")

        elif args.period == "quarterly":
            q = (today.month - 1) // 3
            q_start = {0: 1, 1: 4, 2: 7, 3: 10}[q]
            start = date(today.year, q_start, 1)
            end = today
            label = "%s 季报" % start.strftime("%Y-%m")

        elif args.period == "half_yearly":
            if today.month <= 6:
                start = date(today.year, 1, 1)
                label = "%d年上半年" % today.year
            else:
                start = date(today.year, 7, 1)
                label = "%d年下半年" % today.year
            end = today

        elif args.period == "yearly":
            start = date(args.year, 1, 1)
            end = today if args.year == today.year else date(args.year, 12, 31)
            label = "%d年" % args.year

        days = (end - start).days + 1
        return start, end, days, label

    # 方式四：自定义日期
    if args.start and args.end:
        start = date.fromisoformat(args.start)
        end = date.fromisoformat(args.end)
        days = (end - start).days + 1
        label = "%s ~ %s" % (args.start, args.end)
        return start, end, days, label

    raise ValueError("无法解析时间范围")


def main(argv=None):
    """CLI 入口"""
    args = parse_args(argv)

    # 1. 确定Excel文件路径
    excel_path = args.file
    if not excel_path:
        excel_path = get_default_excel_path()
    if not excel_path or not os.path.exists(excel_path):
        print("错误: 找不到Excel数据文件，请使用 --file 指定路径", file=sys.stderr)
        sys.exit(1)

    # 2. 解析时间范围
    try:
        start_date, end_date, days, label = resolve_date_range(args)
    except ValueError as e:
        print("错误: %s" % e, file=sys.stderr)
        sys.exit(1)

    # 3. 解析运行产线
    running_lines = [int(x.strip()) for x in args.lines.split(",")]

    # 4. 加载数据
    from .loader import ExcelLoader
    from .classifier import Classifier

    cls = Classifier()
    loader = ExcelLoader(excel_path, classifier=cls)
    records = loader.load_by_date_range(start_date, end_date)

    if not records:
        print("警告: 指定时间范围内没有数据", file=sys.stderr)
        sys.exit(0)

    # 5. 如果按月份加载，获取实际有数据的天数
    if args.month and not args.start:
        actual_days = loader.get_month_days(args.year, args.month)
        if actual_days > 0:
            days = actual_days

    # 6. 执行计算
    from .engine import calculate
    result = calculate(records, days=days, running_lines=running_lines,
                       top_n=args.top, classifier=cls)

    # 7. 输出
    if args.output == "json":
        from .formatter import format_json
        print(json.dumps(format_json(result), ensure_ascii=False, indent=2))
    elif args.output == "short":
        print("【%s】综合故障率: %.2f%% | 自身: %.2f%% | 停机: %.0fmin (%.1fh)" % (
            result.period_label,
            result.avg_comprehensive_rate,
            result.avg_own_rate,
            result.total_all_minutes,
            result.total_all_minutes / 60,
        ))
    else:
        from .formatter import format_console
        output = format_console(result)
        print(output)

    return result


if __name__ == "__main__":
    main()
