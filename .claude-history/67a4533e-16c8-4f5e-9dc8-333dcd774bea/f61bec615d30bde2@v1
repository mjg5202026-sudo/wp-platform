@data_bp.route("/impact-factors", methods=["GET"])
def get_impact_factors():
    """???????????"""
    page = request.args.get("page", 1, type=int)
    per_page = request.args.get("per_page", 100, type=int)
    query = OperationImpactFactor.query.order_by(OperationImpactFactor.date.desc())

    total = query.count()
    records = query.offset((page - 1) * per_page).limit(per_page).all()

    return jsonify({
        "data": [r.to_dict() for r in records],
        "total": total,
        "page": page,
        "per_page": per_page,
    })


@data_bp.route("/impact-factors/statistics", methods=["GET"])
def get_impact_statistics():
    """?????????"""
    from sqlalchemy import func

    total_minutes = db.session.query(func.sum(OperationImpactFactor.impact_minutes)).scalar() or 0
    total_records = OperationImpactFactor.query.count()

    return jsonify({
        "data": {
            "total_records": total_records,
            "total_impact_minutes": total_minutes,
            "total_impact_hours": round(total_minutes / 60, 2),
        }
    })


