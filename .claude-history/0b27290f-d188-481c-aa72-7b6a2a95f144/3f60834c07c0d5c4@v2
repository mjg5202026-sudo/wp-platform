"""Read 附件4 - 预算价格和考核细则"""
import sys
sys.path.insert(0, 'D:\\soft\\work-flow\\wp-platform')
import openpyxl

path = 'D:\\soft\\work-flow\\wp-platform\\data\\templates\\附件4 - 2026年绩效管理专项考核细则 Lampiran 4 - Rincian Ketentuan Khusus Penilaian Kinerja.xlsx'
wb = openpyxl.load_workbook(path, data_only=True)
print(f"Sheets: {wb.sheetnames}")

for sn in wb.sheetnames[:3]:
    ws = wb[sn]
    print(f"\n=== {sn} ({ws.max_row}行 x {ws.max_column}列) ===")
    for r in range(1, min(ws.max_row + 1, 50)):
        row = []
        for c in range(1, min(ws.max_column + 1, 15)):
            v = ws.cell(r, c).value
            row.append(str(v)[:40] if v is not None else "")
        if any(cell for cell in row):
            print(f"  R{r}: {' | '.join(row)}")
