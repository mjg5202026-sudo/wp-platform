                f"{reward_text}。"
            )
            break

    # ============================================================
    # 定额材料表格 (Table 0)
    # ============================================================
    excel_path = 'D:\\soft\\work-flow\\wp-platform\\data\\templates\\2026年绩效考核计算.xlsx'
