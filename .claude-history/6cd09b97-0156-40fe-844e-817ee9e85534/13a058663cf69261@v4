def import_impact_factors(file_path: str) -> ExcelImportResult:
    """导入影响作业率因素"""
    result = ExcelImportResult()
    result.table_name = "operation_impact_factors"

    try:
        wb = load_workbook(file_path)
        ws = wb.sheet_by_index(0) if hasattr(wb, "sheet_by_index") else wb.active

        if hasattr(ws, "nrows"):  # xlrd
            rows_total = ws.nrows
            for r in range(1, rows_total):
                try:
                    record = _parse_xls_impact_row(ws, r)
                    if record:
                        db.session.add(record)
                        result.add_success()
                except Exception as e:
                    result.add_error(r + 1, str(e))
        else:  # openpyxl
            header_row = detect_header_row(ws)
            if not header_row:
                result.add_error(0, "???????")
                return result

            headers = parse_header_row(ws, header_row)
            for r in range(header_row + 1, ws.max_row + 1):
                try:
                    row_data = {}
                    is_empty = True
                    for c, h in enumerate(headers):
                        if c >= len(headers):
                            break
                        v = ws.cell(r, c + 1).value
                        if v is not None:
                            is_empty = False
                        row_data[h] = v
                    if is_empty:
                        continue
                    record = _build_impact_from_headers(row_data)
                    if record:
                        db.session.add(record)
                        result.add_success()
                except Exception as e:
                    result.add_error(r + 1, str(e))

        db.session.commit()
    except Exception as e:
        db.session.rollback()
        result.add_error(0, f"??????: {str(e)}")

    return result


def _parse_xls_impact_row(ws, r: int) -> Optional[OperationImpactFactor]:
    """?? xls ???????????"""
    vals = [ws.cell_value(r, c) if c < ws.ncols else "" for c in range(10)]
    if not vals[0] or str(vals[0]).strip() == "":
        return None

    date_str = parse_date_value(vals[0])

    # ????: Excel serial number -> HH:MM
    start_str = None
    end_str = None
    try:
        if isinstance(vals[5], (int, float)):
            from datetime import datetime, date as dt, timedelta
            base = dt(1899, 12, 30)
            s = base + timedelta(days=float(vals[5]))
            start_str = s.strftime("%H:%M")
        else:
            start_str = str(vals[5]) if vals[5] else None
        if isinstance(vals[6], (int, float)):
            from datetime import datetime, date as dt, timedelta
            base = dt(1899, 12, 30)
            e = base + timedelta(days=float(vals[6]))
            end_str = e.strftime("%H:%M")
        else:
            end_str = str(vals[6]) if vals[6] else None
    except:
        pass

    shift = str(vals[1]).strip() if vals[1] else ""
    team = str(vals[2]).strip() if vals[2] else ""
    system = str(vals[3]).strip() if vals[3] else ""
    factor = str(vals[4]).strip() if vals[4] else ""
    impact_min = int(float(str(vals[7]).replace(",", ""))) if vals[7] else 0
    impact_type = str(vals[8]).strip() if vals[8] else ""
    cause = str(vals[9]).strip() if vals[9] else ""

    start_time = None
    end_time = None
    if date_str and start_str:
        ds = date_str.isoformat() if hasattr(date_str, "isoformat") else str(date_str)
        parts = ds.split("-")
        if len(parts) == 3:
            start_time = f"{parts[0]}-{parts[1]}-{parts[2]} {start_str}:00"
    if date_str and end_str:
        ds = date_str.isoformat() if hasattr(date_str, "isoformat") else str(date_str)
        parts = ds.split("-")
        if len(parts) == 3:
            end_time = f"{parts[0]}-{parts[1]}-{parts[2]} {end_str}:00"

    # 解析原始 Python date 对象
    raw_date = parse_date_value(vals[0])
    if raw_date and isinstance(raw_date, str):
        try:
            date_obj = datetime.strptime(raw_date[:10], "%Y-%m-%d").date()
        except:
            date_obj = date.today()
    else:
        date_obj = raw_date or date.today()

    return OperationImpactFactor(
        date=date_obj,
        shift=shift,
        team=team,
        system=system,
        impact_factor=factor,
        impact_minutes=impact_min,
        impact_type=impact_type,
        cause_analysis=cause,
        created_at=datetime.now(),
    )


