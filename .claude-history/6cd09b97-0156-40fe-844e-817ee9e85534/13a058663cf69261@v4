def import_energy_pdf(file_path: str) -> ExcelImportResult:
    """从PDF导入能源消耗统计数据
    基于表格行位置匹配（PDF中文编码乱码，但表格结构固定）
      Table1(6列/5行数据): 电厂发电及原煤消耗
      Table2(7列/7行数据): 冶炼电炉及焙砂生产
    """
    import re
    result = ExcelImportResult()
    result.table_name = "energy_consumptions"

    # 从文件名提取年月: "能源消耗统计表（2026年5月）"
    fname = os.path.basename(file_path)
    ym = re.search(r'(\d{4})\D(\d{1,2})', fname)
    if ym:
        year, month = int(ym.group(1)), int(ym.group(2))
    else:
        year, month = 2026, 5
    record_date = date(year, month, 1)

    try:
        import pdfplumber
        pdf = pdfplumber.open(file_path)
        records_to_add = []

        for page in pdf.pages:
            tables = page.extract_tables()
            if not tables:
                continue

            for table in tables:
                if not table or len(table) < 3:
                    continue

                if not table[0]:
                    continue
                cols = len(table[0])

                # 辅助：尝试获取行的合计值（优先最后一列，降级到第2列/第1台机组数据）
                def _get_val(row):
                    if not row:
                        return None
                    # 尝试最后一列（合计/平均）
                    last = row[-1]
                    if last is not None:
                        try:
                            return float(str(last).replace(",", "").strip())
                        except:
                            pass
                    # 降级到第2列（1#机组/电炉，无法解析为浮点则可能是中文名）
                    if len(row) >= 2:
                        try:
                            v = str(row[1]).replace(",", "").strip()
                            if v:
                                return float(v)
                        except:
                            pass
                    # 降级到第3列（部分单台设备数据在此列）
                    if len(row) >= 3:
                        try:
                            v = str(row[2]).replace(",", "").strip()
                            if v:
                                return float(v)
                        except:
                            pass
                    return None

                # ---- Table1: 电厂发电及原煤消耗 (6列) ----
                if cols == 6:
                    data_rows = table[1:]  # 跳过表头
                    for ri, row in enumerate(data_rows):
                        val = _get_val(row)
                        if val is None:
                            continue

                        # 按行位置确定数据类型
                        if ri == 0:  # 1. 发电量
                            records_to_add.append(EnergyConsumption(
                                date=record_date, energy_type="发电", consumption=val,
                                unit="kWh", generation_amount=val,
                                remark=f"电厂发电量({year}年{month}月)", created_at=datetime.now(),
                            ))
                        elif ri == 1:  # 2. 原煤消耗量
                            records_to_add.append(EnergyConsumption(
                                date=record_date, energy_type="原煤", consumption=val,
                                unit="吨",
                                remark=f"原煤消耗({year}年{month}月)", created_at=datetime.now(),
                            ))
                        elif ri == 2:  # 3. 煤粉消耗量 (序号跳过3)
                            records_to_add.append(EnergyConsumption(
                                date=record_date, energy_type="煤粉", consumption=val,
                                unit="吨",
                                remark=f"煤粉消耗({year}年{month}月)", created_at=datetime.now(),
                            ))
                        elif ri == 3:  # 4. 发电煤耗
                            records_to_add.append(EnergyConsumption(
                                date=record_date, energy_type="发电煤耗",
                                consumption=val, unit="g/kWh",
                                consumption_per_unit=val,
                                remark=f"发电煤耗({year}年{month}月)", created_at=datetime.now(),
                            ))
                        elif ri == 4:  # 5. 化学制水量
                            records_to_add.append(EnergyConsumption(
                                date=record_date, energy_type="新水", consumption=val,
                                unit="吨",
                                remark=f"化学制水量({year}年{month}月)", created_at=datetime.now(),
                            ))

                # ---- Table2: 冶炼电炉及焙砂生产 (7列) ----
                elif cols == 7:
                    data_rows = table[1:]
                    for ri, row in enumerate(data_rows):
                        val = _get_val(row)
                        if val is None:
                            continue

                        if ri == 0:  # 1. 用电量
                            records_to_add.append(EnergyConsumption(
                                date=record_date, energy_type="电", consumption=val,
                                unit="kWh",
                                remark=f"冶炼电炉用电({year}年{month}月)", created_at=datetime.now(),
                            ))
                        elif ri == 1:  # 2. 入炉焙砂量
                            records_to_add.append(EnergyConsumption(
                                date=record_date, energy_type="焙砂", consumption=val,
                                unit="吨",
                                remark=f"入炉焙砂量({year}年{month}月)", created_at=datetime.now(),
                            ))
                        elif ri == 2:  # 3. 产出焙砂量
                            records_to_add.append(EnergyConsumption(
                                date=record_date, energy_type="焙砂产出", consumption=val,
                                unit="吨",
                                remark=f"产出焙砂量({year}年{month}月)", created_at=datetime.now(),
                            ))
                        elif ri == 3:  # 4. 平均负荷率
                            records_to_add.append(EnergyConsumption(
                                date=record_date, energy_type="负荷率",
                                consumption=val, unit="%",
                                remark=f"平均负荷率({year}年{month}月)", created_at=datetime.now(),
                            ))
                        elif ri == 4:  # 5. 产量
                            records_to_add.append(EnergyConsumption(
                                date=record_date, energy_type="产量",
                                consumption=val, unit="吨",
                                remark=f"产量({year}年{month}月)", created_at=datetime.now(),
                            ))
                        elif ri == 5:  # 6. 焙砂电单耗
                            records_to_add.append(EnergyConsumption(
                                date=record_date, energy_type="焙砂电单耗",
                                consumption=val, unit="kWh/T",
                                consumption_per_unit=val,
                                remark=f"焙砂电单耗({year}年{month}月)", created_at=datetime.now(),
                            ))
                        elif ri == 6:  # 7. 冶炼电单耗
                            records_to_add.append(EnergyConsumption(
                                date=record_date, energy_type="冶炼电单耗",
                                consumption=val, unit="kWh/T",
                                consumption_per_unit=val,
                                remark=f"冶炼电单耗({year}年{month}月)", created_at=datetime.now(),
                            ))

        pdf.close()

        if not records_to_add:
            result.add_error(0, "未能从PDF中识别到能源消耗数据，请检查PDF格式")
            return result

        for record in records_to_add:
            db.session.add(record)
            result.add_success()

        db.session.commit()
        print(f"[PDF导入] 成功导入 {result.success} 条能源数据 ({fname})")

    except ImportError:
        result.add_error(0, "缺少pdfplumber库，请执行: pip install pdfplumber")
    except Exception as e:
        db.session.rollback()
        result.add_error(0, f"PDF解析失败: {str(e)}")

    return result


# ============================================================
# 自动导入入口（按表名或文件名自动识别）
# ============================================================
def auto_import(file_path: str, table_name: str = None) -> ExcelImportResult:
    """自动导入入口"""
    result = ExcelImportResult()

    # 检测文件扩展名
    ext = os.path.splitext(file_path)[1].lower()

    # PDF文件 -> 能源数据导入
    if ext == ".pdf":
        return import_energy_pdf(file_path)

    # 未指定表名时按文件名自动识别
    if not table_name:
        fname = os.path.basename(file_path)
        if "作业率" in fname:
            return import_impact_factors(file_path)
        elif "物资" in fname or "材料" in fname or "消耗" in fname:
            return import_materials(file_path)
        elif "能源" in fname or "能耗" in fname or "电" in fname or "柴油" in fname:
            return import_energy(file_path)
        else:
            result.add_error(0, f"无法识别文件类型: {fname}")
            return result

    # 按指定表名导入
    importers = {
        "impact_factors": import_impact_factors,
        "materials": import_materials,
        "energy": import_energy,
    }
    importer = importers.get(table_name)
    if importer:
        return importer(file_path)
    else:
        result.add_error(0, f"不支持的表名: {table_name}")
        return result

