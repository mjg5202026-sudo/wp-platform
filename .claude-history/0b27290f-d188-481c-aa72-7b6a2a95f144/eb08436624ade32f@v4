def read_diesel_data(excel_path, year, month):
    """读取柴油消耗5月数据"""
    import openpyxl
    wb = openpyxl.load_workbook(excel_path, data_only=True)
    ws = wb['26年单耗计算表 (1-5月) (剔除)']

    # 5月列偏移（每月5列: 目标,实际,单耗,超幅,考核；Q1合计占5列）
    if month <= 3:
        col_target = 8 + (month - 1) * 5
    else:
        col_target = 8 + (month - 1) * 5 + 5
    col_actual = col_target + 1
    col_rate = col_target + 3

    # 柴油行及业务年度目标（col 3 = 全年目标）
    dept_rows = {
        "冶炼部": {"row": 16, "annual_col": 7},  # col 7 = 1200812.04
        "生产保障部": {"row": 18, "annual_col": 3},  # col 3 = 2215798
        "营销物流部": {"row": 19, "annual_col": 3, "unit": "升"},  # col 3 = 657556, 按量算
        "电厂部": {"row": 17, "annual_col": 3},  # col 3 = 41014
    }
    FIXED_PRICE = 1.10

    results = []
    for dept, info in dept_rows.items():
        row_idx = info["row"]
        # 年度目标
        annual_col = info.get("annual_col", 3)
        target_annual = float(ws.cell(row_idx, annual_col).value or 0)

        # 5月数据
        target_month = ws.cell(row_idx, col_target).value
        actual_month = ws.cell(row_idx, col_actual).value
        rate = ws.cell(row_idx, col_rate).value

        target_m = float(target_month) if target_month else 0
        actual_m = float(actual_month) if actual_month else 0
        rate_val = float(rate) if rate else 0

        # 如果5月目标为空，用年度/12
        if target_m == 0 and target_annual > 0:
            target_m = round(target_annual / 12, 2)

        # 影响数量 = 实际 - 目标
        impact_qty = round(actual_m - target_m, 2)
        # 影响金额 = 超预算数量 * 固定价格(只算超的部分)
        impact_amount = round(max(impact_qty, 0) * FIXED_PRICE, 2) if impact_qty > 0 else 0
        # 超幅
        rate_display = f"{rate_val*100:.2f}%" if rate_val > 0 else "/"

        results.append({
            "dept": dept,
            "unit": info.get("unit", "升"),
            "annual_target": target_annual,
            "month_target": target_m,
            "month_actual": actual_m,
            "rate_display": rate_display,
            "impact_amount": impact_amount,
        })

    wb.close()
    return results


