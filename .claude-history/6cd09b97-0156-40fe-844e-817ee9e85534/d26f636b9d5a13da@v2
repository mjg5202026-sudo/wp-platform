from datetime import datetime, date
from flask import Blueprint, request, jsonify
from sqlalchemy import func

from backend.models import db, InspectionIssue

inspection_bp = Blueprint("inspections", __name__)


@inspection_bp.route("/list", methods=["GET"])
def get_inspections():
    """????????"""
    page = request.args.get("page", 1, type=int)
    per_page = request.args.get("per_page", 50, type=int)
    status = request.args.get("status")
    severity = request.args.get("severity")
    date_from = request.args.get("date_from")
    date_to = request.args.get("date_to")

    query = InspectionIssue.query
    if status:
        query = query.filter(InspectionIssue.rectification_status == status)
    if severity:
        query = query.filter(InspectionIssue.severity == severity)
    if date_from:
        query = query.filter(InspectionIssue.inspection_date >= date_from)
    if date_to:
        query = query.filter(InspectionIssue.inspection_date <= date_to)

    query = query.order_by(InspectionIssue.inspection_date.desc())
    total = query.count()
    records = query.offset((page - 1) * per_page).limit(per_page).all()

    return jsonify({"data": [r.to_dict() for r in records], "total": total})


@inspection_bp.route("/add", methods=["POST"])
def add_issue():
    """??????"""
    data = request.get_json()
    if not data or not data.get("issue_description"):
        return jsonify({"status": "error", "message": "????????"}), 400

    try:
        record = InspectionIssue(
            inspection_date=datetime.strptime(data["inspection_date"], "%Y-%m-%d").date() if data.get("inspection_date") else date.today(),
            inspection_type=data.get("inspection_type", ""),
            issue_description=data["issue_description"],
            location=data.get("location", ""),
            severity=data.get("severity", "??"),
            image_paths=data.get("image_paths", []),
            rectification_measure=data.get("rectification_measure", ""),
            responsible_person=data.get("responsible_person", ""),
            deadline=datetime.strptime(data["deadline"], "%Y-%m-%d").date() if data.get("deadline") else None,
            rectification_status=data.get("rectification_status", "???"),
            remark=data.get("remark", ""),
            created_at=datetime.now(),
        )
        db.session.add(record)
        db.session.commit()
        return jsonify({"status": "ok", "message": "????", "data": record.to_dict()})
    except Exception as e:
        db.session.rollback()
        return jsonify({"status": "error", "message": str(e)}), 500


@inspection_bp.route("/update/<int:issue_id>", methods=["PUT"])
def update_issue(issue_id):
    """??????"""
    record = InspectionIssue.query.get(issue_id)
    if not record:
        return jsonify({"status": "error", "message": "?????"}), 404

    data = request.get_json()
    try:
        for field in ["issue_description", "location", "severity", "rectification_measure",
                       "responsible_person", "rectification_status", "remark", "inspection_type"]:
            if field in data:
                setattr(record, field, data[field])
        if "deadline" in data and data["deadline"]:
            record.deadline = datetime.strptime(data["deadline"], "%Y-%m-%d").date()
        if data.get("rectification_status") == "已完成":
            record.completion_date = date.today()
            record.is_closed = True
        record.updated_at = datetime.now()
        db.session.commit()
        return jsonify({"status": "ok", "message": "已更新", "data": record.to_dict()})
    except Exception as e:
        db.session.rollback()
        return jsonify({"status": "error", "message": str(e)}), 500


@inspection_bp.route("/statistics", methods=["GET"])
def get_statistics():
    """????"""
    total = InspectionIssue.query.count()
    closed = InspectionIssue.query.filter(InspectionIssue.is_closed == True).count()
    rectifying = InspectionIssue.query.filter(InspectionIssue.rectification_status == "整改中").count()
    not_started = InspectionIssue.query.filter(InspectionIssue.rectification_status == "未开始").count()
    overdue = InspectionIssue.query.filter(InspectionIssue.overdue_days > 0).count()

    return jsonify({
        "data": {
            "total": total,
            "closed": closed,
            "closed_rate": round(closed / total * 100, 1) if total > 0 else 0,
            "rectifying": rectifying,
            "not_started": not_started,
            "overdue": overdue,
            "overdue_rate": round(overdue / total * 100, 1) if total > 0 else 0,
        }
    })


