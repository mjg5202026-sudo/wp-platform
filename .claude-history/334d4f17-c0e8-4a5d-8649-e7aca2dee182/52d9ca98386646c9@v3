const FONT = "宋体";
const border = { style: BorderStyle.SINGLE, size: 1, color: "000000" };
const borders = { top: border, bottom: border, left: border, right: border };
const cellMargins = { top: 60, bottom: 60, left: 100, right: 100 };

function tr(text, opts = {}) {
  return new TextRun({ text, font: opts.font || FONT, size: opts.size || 21, bold: opts.bold || false });
}

function p(texts, opts = {}) {
  const arr = Array.isArray(texts) ? texts : [tr(texts)];
  return new Paragraph({ children: arr, alignment: opts.alignment, spacing: opts.spacing || { after: 40 }, indent: opts.indent });
}

function cell(children, opts = {}) {
  return new TableCell({
    borders,
    width: opts.width ? { size: opts.width, type: WidthType.DXA } : undefined,
    shading: opts.shading ? { fill: opts.shading, type: ShadingType.CLEAR } : undefined,
    margins: cellMargins,
    verticalAlign: opts.vAlign || "center",
    children: Array.isArray(children) ? children : [p(children, { alignment: opts.alignment })],
  });
}

function cellPara(text, opts = {}) {
  return cell([new Paragraph({
    children: [tr(text, { bold: opts.bold, size: opts.size || 21 })],
    alignment: opts.alignment || AlignmentType.CENTER,
    spacing: { after: 0 },
  })], opts);
}

