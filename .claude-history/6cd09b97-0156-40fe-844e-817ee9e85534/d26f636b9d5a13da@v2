def delete_issue(issue_id):
    """????"""
    record = InspectionIssue.query.get(issue_id)
    if not record:
        return jsonify({"status": "error", "message": "?????"}), 404
    db.session.delete(record)
    db.session.commit()
    return jsonify({"status": "ok", "message": "????"})
