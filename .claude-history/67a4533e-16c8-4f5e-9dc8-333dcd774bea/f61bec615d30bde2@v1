@data_bp.route("/preview", methods=["POST"])
def preview_file():
    """?? Excel ???? (???)"""
    if "file" not in request.files:
        return jsonify({"status": "error", "message": "?????"}), 400

    file = request.files["file"]
    if not allowed_file(file.filename):
        return jsonify({"status": "error", "message": "????????"}), 400

    ext = os.path.splitext(file.filename)[1].lower()
    saved_name = f"preview_{uuid.uuid4().hex}{ext}"
    save_path = os.path.join(current_app.config.get("UPLOAD_DIR", "data/uploads"), saved_name)
    file.save(save_path)

    try:
        wb = load_workbook(save_path)
        sheets = []

        if hasattr(wb, "sheet_names"):
            for sn in wb.sheet_names():
                ws = wb.sheet_by_name(sn)
                preview = {"name": sn, "rows": ws.nrows, "cols": ws.ncols, "data": []}
                for r in range(min(5, ws.nrows)):
                    row = []
                    for c in range(min(10, ws.ncols)):
                        v = ws.cell_value(r, c)
                        row.append(str(v)[:50] if v != "" else "")
                    preview["data"].append(row)
                sheets.append(preview)
        else:
            for sn in wb.sheetnames:
                ws = wb[sn]
                preview = {"name": sn, "rows": ws.max_row, "cols": ws.max_column, "data": []}
                for r in range(1, min(6, ws.max_row + 1)):
                    row = []
                    for c in range(1, min(11, ws.max_column + 1)):
                        v = ws.cell(r, c).value
                        row.append(str(v)[:50] if v is not None else "")
                    preview["data"].append(row)
                sheets.append(preview)

        return jsonify({
            "status": "ok",
            "filename": file.filename,
            "sheets": sheets,
        })
    except Exception as e:
        return jsonify({"status": "error", "message": f"??????: {str(e)}"}), 500
    finally:
        try:
            os.remove(save_path)
        except:
            pass


