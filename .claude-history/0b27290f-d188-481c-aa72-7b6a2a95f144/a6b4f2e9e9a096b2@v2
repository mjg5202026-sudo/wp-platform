def _get_targets(year: int, month: int) -> Dict:
    """??????"""
    targets = {}
    # ? InventoryTarget ????
    records = InventoryTarget.query.filter_by(year=year).all()
    for r in records:
        if "??" in r.category:
            targets["diesel"] = r.reduction_rate or 5
        elif "??" in r.category:
            targets["water"] = r.reduction_rate or 5
        elif "???" in r.category:
            targets["lubricant"] = r.reduction_rate or 5
        elif "??" in r.category:
            targets["parts"] = r.reduction_rate or 10
        elif "??" in r.category:
            targets["material"] = r.reduction_rate or 5

    # ????
    targets.setdefault("diesel", 5)
    targets.setdefault("water", 5)
    targets.setdefault("lubricant", 5)
    targets.setdefault("parts", 10)
    targets.setdefault("material", 5)
    return targets


def _calc_reduction_rate(year: int, month: int, energy_type: str) -> float:
    """??????????????????

    ????: (???? - ?????) / ????? * 100

    ?????????????????
    """
    if month > 1:
        # ??: ????????
        cur = db.session.query(db.func.sum(EnergyConsumption.consumption))            .filter(db.extract("YEAR", EnergyConsumption.date) == year)            .filter(db.extract("MONTH", EnergyConsumption.date) == month)            .filter(EnergyConsumption.energy_type == energy_type).scalar() or 0
        prev = db.session.query(db.func.sum(EnergyConsumption.consumption))            .filter(db.extract("YEAR", EnergyConsumption.date) == year)            .filter(db.extract("MONTH", EnergyConsumption.date) == month - 1)            .filter(EnergyConsumption.energy_type == energy_type).scalar() or 0
        if prev > 0:
            return round((cur - prev) / prev * 100, 2)
    return 0.0


def _calc_parts_reduction(year: int, month: int) -> float:
    """???????"""
    cur = db.session.query(db.func.sum(MaterialConsumption.total_amount))        .filter(db.extract("YEAR", MaterialConsumption.date) == year)        .filter(db.extract("MONTH", MaterialConsumption.date) == month)        .scalar() or 0
    prev = db.session.query(db.func.sum(MaterialConsumption.total_amount))        .filter(db.extract("YEAR", MaterialConsumption.date) == year)        .filter(db.extract("MONTH", MaterialConsumption.date) == month - 1)        .scalar() or 0
    if prev > 0:
        return round((cur - prev) / prev * 100, 2)
    return 5.0  # ????


def _calc_material_reduction(year: int, month: int) -> float:
    """???????"""
    return _calc_parts_reduction(year, month)


