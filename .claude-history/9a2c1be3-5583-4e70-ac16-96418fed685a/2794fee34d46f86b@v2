# Repack
with zipfile.ZipFile(fp, 'w', zipfile.ZIP_DEFLATED) as zout:
    for root, dirs, files in os.walk(tmpdir):
        for file in files:
            zout.write(os.path.join(root, file), os.path.relpath(os.path.join(root, file), tmpdir))

shutil.rmtree(tmpdir)

# Verify
