def sf(run, fn='仿宋_GB2312', ea='仿宋_GB2312', sz=16, b=False):
    run.font.size = Pt(sz); run.bold = b
    rPr = run._element.find(qn('w:rPr'))
    if rPr is None: rPr = OxmlElement('w:rPr'); run._element.insert(0, rPr)
    rF = rPr.find(qn('w:rFonts'))
    if rF is None: rF = OxmlElement('w:rFonts'); rPr.insert(0, rF)
    rF.set(qn('w:ascii'), fn); rF.set(qn('w:hAnsi'), fn); rF.set(qn('w:eastAsia'), ea)

def T(doc, text):
