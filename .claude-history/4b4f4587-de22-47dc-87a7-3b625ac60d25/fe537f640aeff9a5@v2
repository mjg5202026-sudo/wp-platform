# -*- coding: utf-8 -*-
import xlrd, sys, io
from collections import defaultdict

sys.stdout = io.TextIOWrapper(sys.stdout.buffer, encoding='utf-8')

wb = xlrd.open_workbook(r'D:\soft\work-flow\wp-platform\data\templates\影响作业率因素统计 2026(4).xls')
sh = wb.sheet_by_index(0)
datemode = wb.datemode

def hex_id(s):
    return s.encode('utf-8').hex()

def should_exclude_reason(reason_str):
    h = hex_id(reason_str)
    if h == 'e7949fe4baa7e7bb84e7bb87': return True
    if h == 'e8aea1e58892e680a7e6a380e4bfae': return True
    if 'e4bf9de99a9c' in h: return True
    if 'e8bda6e8be86' in h: return True
    return False

def is_dianlu(line_str):
    return hex_id(line_str).endswith('e794b5e78289')

def is_limo(factor_str):
    return 'e7ab8be7a3a8' in hex_id(factor_str)

def line_num(line_str):
    h = hex_id(line_str)
    for n, p in [(1,'31'),(2,'32'),(3,'33')]:
        if h.startswith(p): return n
    return 0

# ==== 读取数据 ====
records = []
for r in range(1, sh.nrows):
    v = sh.cell_value(r, 0)
    if isinstance(v, (int, float)) and v > 40000:
        t = xlrd.xldate_as_tuple(v, datemode)
        if t[1] == 6 and t[0] == 2026:
            line = str(sh.cell_value(r, 3)).strip()
            reason = str(sh.cell_value(r, 9)).strip()
            factor = str(sh.cell_value(r, 4)).strip()
            mins = sh.cell_value(r, 7)
            ln = line_num(line)
            if 1 <= ln <= 3 and isinstance(mins, (int, float)) and mins > 0:
                if not should_exclude_reason(reason):
                    records.append({
                        'day': t[2], 'ln': ln, 'line': line,
                        'factor': factor, 'mins': mins,
                        'is_dianlu': is_dianlu(line),
                        'is_limo': is_limo(factor),
                    })

# 先按 (日期, 线号, 因素) 分组，看看立磨事件出现在哪些天
limo_days_by_line = defaultdict(set)
for rec in records:
    if rec['is_limo']:
        limo_days_by_line[rec['ln']].add(rec['day'])

print("=== 各线立磨故障发生的日期 ===")
for ln in [1,2,3]:
    days = sorted(limo_days_by_line[ln])
    print(f"  {ln}#线: 共{len(days)}天 -> {days}")
print()

# 看在这些有立磨的日期里，非立磨事件有哪些
print("=== 立磨故障当天，同线发生的其他检修活动 ===")
print()
for ln in [1,2,3]:
    limo_days = limo_days_by_line[ln]
    other_on_limo_days = defaultdict(list)
    for rec in records:
        if rec['ln'] == ln and rec['day'] in limo_days and not rec['is_limo']:
            other_on_limo_days[rec['day']].append(rec)

    print(f"  {ln}#线:")
    for d in sorted(other_on_limo_days.keys()):
        print(f"    {d}日 ({len(other_on_limo_days[d])}条):")
        for rec in other_on_limo_days[d]:
            # Try to identify equipment type
            equip = "电炉" if rec['is_dianlu'] else "其他"
            print(f"      - [{equip}] {rec['factor'][:50]} ({rec['mins']:.0f}min)")
    print()

# 也看看非立磨日期里的非立磨事件（这些才是真正的产线独立故障）
print("=== 非立磨日期里的产线自身故障 ===")
for ln in [1,2,3]:
    limo_days = limo_days_by_line[ln]
    own_mins = 0
    own_items = []
    seen = set()
    for rec in records:
        if rec['ln'] == ln and rec['day'] not in limo_days and not rec['is_limo']:
            key = (rec['day'], rec['factor'])
            if key not in seen:
                seen.add(key)
                own_items.append(rec)
                own_mins += rec['mins']
    print(f"  {ln}#线: 非立磨日停机合计 {own_mins:.0f}min")
    for rec in sorted(own_items, key=lambda x: -x['mins'])[:5]:
        equip = "电炉" if rec['is_dianlu'] else "其他"
        print(f"    - {rec['day']}日 [{equip}] {rec['factor'][:50]} ({rec['mins']:.0f}min)")
    print()
